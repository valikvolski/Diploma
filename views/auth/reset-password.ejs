<%- include('../partials/header', { title: 'Новый пароль — МедЗапись' }) %>

<div class="auth-page auth-wrapper">
  <div class="auth-shell" style="max-width: 520px;">
    <div class="auth-card auth-card--wide ds-auth-card card border-0">
      <div class="ds-auth-card__head text-white text-center py-4 px-4">
        <div class="ds-auth-card__mark"><i class="bi bi-key-fill"></i></div>
        <h1 class="h4 fw-bold mb-1">Новый пароль</h1>
        <p class="small opacity-75 mb-0">Введите код из письма и придумайте пароль</p>
      </div>
      <div class="card-body p-4 p-md-5">

        <% if (typeof infoSent !== 'undefined' && infoSent) { %>
          <div class="alert alert-success d-flex align-items-start gap-2" role="status">
            <i class="bi bi-check-circle-fill flex-shrink-0 mt-1"></i>
            <span>Если указанный аккаунт существует, на email отправлен код. Проверьте почту (и папку «Спам»).</span>
          </div>
        <% } %>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
            <span><%= error %></span>
          </div>
        <% } %>

        <form method="POST" action="/auth/reset-password" novalidate class="mt-2">
          <%- include('../partials/csrf') %>
          <div class="mb-3">
            <label for="email" class="form-label fw-semibold">Электронная почта</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text"><i class="bi bi-envelope"></i></span>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                required
                placeholder="name@example.com"
                autocomplete="email"
                value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
              />
            </div>
          </div>

          <div class="mb-3">
            <label for="code" class="form-label fw-semibold">Код из письма</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text"><i class="bi bi-shield-check"></i></span>
              <input
                type="text"
                class="form-control"
                id="code"
                name="code"
                required
                inputmode="numeric"
                pattern="[0-9\s]*"
                maxlength="12"
                placeholder="000000"
                autocomplete="one-time-code"
                value="<%= typeof formData !== 'undefined' && formData.code ? formData.code : '' %>"
              />
            </div>
            <div class="form-text">6 цифр из письма</div>
          </div>

          <div class="mb-3">
            <label for="password" class="form-label fw-semibold">Новый пароль</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text"><i class="bi bi-key"></i></span>
              <input
                type="password"
                class="form-control"
                id="password"
                name="password"
                required
                minlength="6"
                placeholder="Не менее 6 символов"
                autocomplete="new-password"
              />
              <button class="btn btn-outline-secondary" type="button" id="togglePassword" aria-pressed="false">
                <i class="bi bi-eye"></i>
              </button>
            </div>
          </div>

          <div class="mb-4">
            <label for="password_confirm" class="form-label fw-semibold">Повторите пароль</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
              <input
                type="password"
                class="form-control"
                id="password_confirm"
                name="password_confirm"
                required
                minlength="6"
                placeholder="Ещё раз"
                autocomplete="new-password"
              />
            </div>
          </div>

          <button type="submit" class="btn btn-primary w-100 py-2 rounded-pill fw-semibold mb-3">
            <i class="bi bi-check-lg me-2"></i>Сохранить пароль
          </button>
        </form>

        <p class="text-center text-muted small mb-2">
          Нет кода?
          <a href="/auth/forgot-password" class="fw-semibold text-decoration-none">Запросить снова</a>
        </p>
        <p class="text-center mb-0 text-muted small">
          <a href="/auth/login" class="fw-semibold text-decoration-none">← К входу</a>
        </p>
      </div>
    </div>
  </div>
</div>

<script src="/js/auth-forms.js"></script>
<%- include('../partials/footer') %>
