<%- include('../partials/header', { title: 'Регистрация — МедЗапись' }) %>

<div class="auth-page auth-wrapper">
  <div class="auth-shell" style="max-width: 520px;">
    <div class="auth-card auth-card--wide ds-auth-card card border-0">
      <div class="ds-auth-card__head text-white text-center py-4 px-4">
        <div class="ds-auth-card__mark"><i class="bi bi-person-plus"></i></div>
        <h1 class="h4 fw-bold mb-1">Регистрация пациента</h1>
        <p class="small opacity-75 mb-0">Создайте аккаунт для записи к врачам</p>
      </div>
      <div class="card-body p-4 p-md-5">

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
            <span><%= error %></span>
          </div>
        <% } %>

        <form method="POST" action="/auth/register" novalidate id="registerForm" class="mt-2">

          <div class="mb-3">
            <label for="email" class="form-label fw-semibold">Электронная почта</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text"><i class="bi bi-envelope"></i></span>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                value="<%= typeof formData !== 'undefined' ? formData.email || '' : '' %>"
                required
                placeholder="name@example.com"
                autocomplete="email"
              />
            </div>
          </div>

          <div class="mb-3">
            <label for="password" class="form-label fw-semibold">Пароль</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text"><i class="bi bi-key"></i></span>
              <input
                type="password"
                class="form-control"
                id="password"
                name="password"
                required
                minlength="6"
                placeholder="Не менее 6 символов"
                autocomplete="new-password"
              />
              <button class="btn btn-outline-secondary" type="button" id="togglePassword" aria-pressed="false">
                <i class="bi bi-eye"></i>
              </button>
            </div>
            <div id="passwordStrength" class="mt-1"></div>
          </div>

          <div class="mb-3">
            <label for="password_confirm" class="form-label fw-semibold">Подтвердите пароль</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text"><i class="bi bi-shield-check"></i></span>
              <input
                type="password"
                class="form-control"
                id="password_confirm"
                name="password_confirm"
                required
                minlength="6"
                placeholder="Повторите пароль"
                autocomplete="new-password"
              />
              <button class="btn btn-outline-secondary" type="button" id="toggleConfirm" aria-pressed="false">
                <i class="bi bi-eye"></i>
              </button>
            </div>
            <div id="confirmFeedback" class="form-text"></div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label for="last_name" class="form-label fw-semibold">Фамилия</label>
              <input
                type="text"
                class="form-control"
                id="last_name"
                name="last_name"
                value="<%= typeof formData !== 'undefined' ? formData.last_name || '' : '' %>"
                required
                placeholder="Иванов"
                autocomplete="family-name"
              />
            </div>
            <div class="col-md-6">
              <label for="first_name" class="form-label fw-semibold">Имя</label>
              <input
                type="text"
                class="form-control"
                id="first_name"
                name="first_name"
                value="<%= typeof formData !== 'undefined' ? formData.first_name || '' : '' %>"
                required
                placeholder="Иван"
                autocomplete="given-name"
              />
            </div>
          </div>

          <div class="mb-3">
            <label for="middle_name" class="form-label fw-semibold">Отчество</label>
            <input
              type="text"
              class="form-control"
              id="middle_name"
              name="middle_name"
              value="<%= typeof formData !== 'undefined' ? formData.middle_name || '' : '' %>"
              required
              placeholder="Иванович"
              autocomplete="additional-name"
            />
          </div>

          <div class="mb-4">
            <label for="phone" class="form-label fw-semibold">Телефон (РБ)</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text"><i class="bi bi-phone"></i></span>
              <input
                type="tel"
                class="form-control"
                id="phone"
                name="phone"
                value="<%= typeof formData !== 'undefined' ? formData.phone || '' : '' %>"
                required
                pattern="\+375[0-9]{9}"
                placeholder="+375291234567"
                autocomplete="tel"
                maxlength="13"
              />
            </div>
            <div class="form-text">Формат: <strong>+375</strong> и 9 цифр (например +375291234567)</div>
          </div>

          <button type="submit" class="btn btn-primary w-100 py-2 rounded-pill fw-semibold" id="submitBtn">
            <i class="bi bi-person-check me-2"></i>Создать аккаунт
          </button>
        </form>

        <p class="text-center mt-4 mb-0 text-muted small">
          Уже есть аккаунт?
          <a href="/auth/login" class="fw-semibold text-decoration-none">Войти</a>
        </p>
      </div>
    </div>
  </div>
</div>

<script src="/js/auth-forms.js"></script>
<%- include('../partials/footer') %>
