<%- include('../partials/header', { title: 'Вход — МедЗапись' }) %>

<div class="auth-page auth-wrapper">
  <div class="auth-shell">
    <div class="auth-card ds-auth-card card border-0">
      <div class="ds-auth-card__head text-white text-center py-4 px-4">
        <div class="ds-auth-card__mark"><i class="bi bi-shield-lock"></i></div>
        <h1 class="h4 fw-bold mb-1">Вход в кабинет</h1>
        <p class="small opacity-75 mb-0">МедЗапись — запись к врачу онлайн</p>
      </div>
      <div class="card-body p-4 p-md-5">

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
            <span><%= error %></span>
          </div>
        <% } %>

        <% if (typeof success !== 'undefined' && success) { %>
          <div class="alert alert-success d-flex align-items-start gap-2" role="alert">
            <i class="bi bi-check-circle-fill flex-shrink-0 mt-1"></i>
            <span><%= success %></span>
          </div>
        <% } %>

        <% var nextPath = typeof next !== 'undefined' && next ? next : '/'; %>
        <form method="POST" action="/auth/login" novalidate class="mt-2">
          <input type="hidden" name="next" value="<%= nextPath %>" />
          <div class="mb-3">
            <label for="email" class="form-label fw-semibold">Электронная почта</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text" id="email-addon"><i class="bi bi-envelope"></i></span>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                required
                placeholder="name@example.com"
                autofocus
                autocomplete="email"
                aria-describedby="email-addon"
                value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
              />
            </div>
          </div>

          <div class="mb-2">
            <label for="password" class="form-label fw-semibold">Пароль</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text"><i class="bi bi-key"></i></span>
              <input
                type="password"
                class="form-control"
                id="password"
                name="password"
                required
                placeholder="Введите пароль"
                autocomplete="current-password"
              />
              <button class="btn btn-outline-secondary" type="button" id="togglePassword" aria-pressed="false">
                <i class="bi bi-eye"></i>
              </button>
            </div>
          </div>

          <div class="text-end mb-4">
            <span class="small text-muted">Забыли пароль? Обратитесь в регистратуру</span>
          </div>

          <button type="submit" class="btn btn-primary w-100 py-2 rounded-pill fw-semibold">
            <i class="bi bi-box-arrow-in-right me-2"></i>Войти
          </button>
        </form>

        <% if (typeof googleAuthEnabled !== 'undefined' && googleAuthEnabled) { %>
        <div class="d-flex align-items-center gap-2 my-4">
          <hr class="flex-grow-1 opacity-25" />
          <span class="small text-muted text-nowrap">или</span>
          <hr class="flex-grow-1 opacity-25" />
        </div>
        <a href="/auth/google" class="btn btn-outline-secondary w-100 py-2 rounded-pill fw-semibold d-inline-flex align-items-center justify-content-center gap-2">
          <i class="bi bi-google"></i>
          Продолжить с Google
        </a>
        <% } %>

        <p class="text-center mt-4 mb-0 text-muted small">
          Нет аккаунта?
          <a href="/auth/register" class="fw-semibold text-decoration-none">Зарегистрироваться</a>
        </p>
      </div>
    </div>
  </div>
</div>

<script src="/js/auth-forms.js"></script>
<%- include('../partials/footer') %>
