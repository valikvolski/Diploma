<%- include('../partials/header', { title: 'Восстановление пароля — МедЗапись' }) %>

<div class="auth-page auth-wrapper">
  <div class="auth-shell" style="max-width: 480px;">
    <div class="auth-card ds-auth-card card border-0">
      <div class="ds-auth-card__head text-white text-center py-4 px-4">
        <div class="ds-auth-card__mark"><i class="bi bi-envelope-paper"></i></div>
        <h1 class="h4 fw-bold mb-1">Забыли пароль?</h1>
        <p class="small opacity-75 mb-0">Отправим код на вашу почту</p>
      </div>
      <div class="card-body p-4 p-md-5">

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
            <span><%= error %></span>
          </div>
        <% } %>

        <p class="small text-muted mb-4">
          Укажите email аккаунта. Если он зарегистрирован, вы получите <strong>6-значный код</strong> (действует около 10&nbsp;минут).
          Дальше введите код и новый пароль на следующей странице.
        </p>

        <form method="POST" action="/auth/forgot-password" novalidate class="mt-2">
          <%- include('../partials/csrf') %>
          <div class="mb-4">
            <label for="email" class="form-label fw-semibold">Электронная почта</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text" id="email-addon"><i class="bi bi-envelope"></i></span>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                required
                placeholder="name@example.com"
                autofocus
                autocomplete="email"
                aria-describedby="email-addon"
                value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
              />
            </div>
          </div>

          <button type="submit" class="btn btn-primary w-100 py-2 rounded-pill fw-semibold mb-3">
            <i class="bi bi-send me-2"></i>Отправить код
          </button>
        </form>

        <p class="text-center mb-0 text-muted small">
          <a href="/auth/login" class="fw-semibold text-decoration-none">← Назад к входу</a>
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
