<%
const MONTHS = ['января','февраля','марта','апреля','мая','июня','июля','августа','сентября','октября','ноября','декабря'];
function fmtDate(s){ if(!s)return ''; const p=String(s).split('-'); return parseInt(p[2],10)+' '+MONTHS[parseInt(p[1],10)-1]+' '+p[0]; }
function typeIcon(t){
  switch(t){
    case 'warning':return '<i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>';
    case 'success':return '<i class="bi bi-check-circle-fill text-success me-2"></i>';
    default:return '<i class="bi bi-info-circle-fill text-primary me-2"></i>';
  }
}
function typeBg(t, read){
  if(!read) return 'bg-light border-start border-4 border-' + (t==='warning'?'warning':t==='success'?'success':'primary');
  return '';
}
%>
<%- include('../partials/header', { title: title }) %>

<div class="page-header d-flex flex-wrap justify-content-between align-items-start gap-3">
  <div>
    <h1 class="page-header__title"><i class="bi bi-bell text-primary me-2"></i>Уведомления</h1>
    <p class="page-header__meta mb-0">Сообщения о записях и изменениях</p>
  </div>
  <% if (notifications.some(n => !n.is_read)) { %>
    <form method="POST" action="/notifications/read-all" class="flex-shrink-0">
      <button class="btn btn-outline-primary btn-sm rounded-pill"><i class="bi bi-check-all me-1"></i>Все прочитаны</button>
    </form>
  <% } %>
</div>

<% if (notifications.length === 0) { %>
  <div class="empty-state text-center app-card p-5">
    <div class="empty-state__icon text-muted"><i class="bi bi-bell-slash"></i></div>
    <p class="text-muted mt-2 mb-0">Уведомлений нет</p>
  </div>
<% } else { %>
  <%
    let currentDate = '';
  %>
  <div class="d-flex flex-column gap-2">
    <% notifications.forEach(function(n) { %>
      <% if (n.date_str !== currentDate) { currentDate = n.date_str; %>
        <div class="text-muted small fw-semibold mt-3 mb-1"><%= fmtDate(n.date_str) %></div>
      <% } %>
      <div class="card border-0 shadow-sm notification-item <%= typeBg(n.type, n.is_read) %> <%= n.is_read ? 'opacity-65' : '' %>"
           data-id="<%= n.id %>" data-read="<%= n.is_read %>">
        <div class="card-body py-3 px-4">
          <div class="d-flex align-items-start">
            <div class="flex-shrink-0 mt-1"><%- typeIcon(n.type) %></div>
            <div class="flex-grow-1">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <strong class="<%= n.is_read ? 'fw-normal' : 'fw-bold' %>"><%= n.title %></strong>
                <small class="text-muted ms-2"><%= n.time_str %></small>
              </div>
              <div class="small text-muted"><%= n.message %></div>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<script>
document.querySelectorAll('.notification-item[data-read="false"]').forEach(function(el) {
  el.addEventListener('click', function() {
    const id = this.dataset.id;
    fetch('/notifications/' + id + '/read', { method: 'POST' }).then(function() {
      el.classList.add('opacity-65');
      el.classList.remove('bg-light', 'border-start', 'border-4');
      el.dataset.read = 'true';
      if (typeof updateNotificationBadge === 'function') updateNotificationBadge();
    });
  });
});
</script>

<%- include('../partials/footer') %>
