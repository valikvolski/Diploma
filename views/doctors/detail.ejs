<%
function experienceLabel(n) {
  if (n % 100 >= 11 && n % 100 <= 19) return 'лет';
  switch (n % 10) {
    case 1: return 'год';
    case 2: case 3: case 4: return 'года';
    default: return 'лет';
  }
}
%>
<%- include('../partials/header', { title: title }) %>
<% var dsTitle = doctor.last_name + ' ' + doctor.first_name; var dsSubtitle = [doctor.middle_name, 'Карточка врача и запись на приём'].filter(Boolean).join(' · '); var dsIcon = 'bi-person-badge'; var dsBackHref = '/doctors'; var dsBackLabel = 'К каталогу'; %>
<%- include('../partials/ds-page-header') %>

<div class="row g-4">

  <!-- Левая колонка: аватар + мета -->
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm text-center p-4 app-card">

      <div class="doctor-detail-avatar-wrap mx-auto mb-3">
        <%- include('../partials/user-avatar', { person: doctor, size: 'detail' }) %>
      </div>

      <h4 class="fw-bold mb-1">
        <%= doctor.last_name %> <%= doctor.first_name %>
      </h4>
      <p class="text-muted mb-3"><%= doctor.middle_name %></p>

      <% const dspecs = Array.isArray(doctor.specializations) ? doctor.specializations : []; %>
      <% if (dspecs.length) { %>
        <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
          <% dspecs.forEach(function(sp) { %>
            <span class="badge spec-badge fs-6<%= sp.is_primary ? '' : ' bg-light text-dark border' %>"><%= sp.name %></span>
          <% }); %>
        </div>
      <% } %>

      <ul class="list-unstyled doctor-detail-meta text-start mt-3">
        <% if (doctor.cabinet) { %>
          <li class="d-flex align-items-center gap-2 py-2 border-bottom">
            <i class="bi bi-door-open text-primary fs-5"></i>
            <div>
              <div class="small text-muted">Кабинет</div>
              <div class="fw-semibold">№ <%= doctor.cabinet %></div>
            </div>
          </li>
        <% } %>
        <% if (doctor.experience_years > 0) { %>
          <li class="d-flex align-items-center gap-2 py-2 border-bottom">
            <i class="bi bi-award text-primary fs-5"></i>
            <div>
              <div class="small text-muted">Стаж работы</div>
              <div class="fw-semibold"><%= doctor.experience_years %> <%= experienceLabel(doctor.experience_years) %></div>
            </div>
          </li>
        <% } %>
        <% if (doctor.phone) { %>
          <li class="d-flex align-items-center gap-2 py-2">
            <i class="bi bi-telephone text-primary fs-5"></i>
            <div>
              <div class="small text-muted">Телефон</div>
              <div class="fw-semibold"><%= doctor.phone %></div>
            </div>
          </li>
        <% } %>
      </ul>

    </div>
  </div>

  <!-- Правая колонка: детали -->
  <div class="col-lg-8 d-flex flex-column gap-4">

    <!-- Описание -->
    <% if (doctor.description) { %>
      <div class="card border-0 shadow-sm p-4 app-card">
        <h5 class="fw-bold mb-3">
          <i class="bi bi-info-circle text-primary me-2"></i>О враче
        </h5>
        <p class="text-secondary mb-0 lh-lg"><%= doctor.description %></p>
      </div>
    <% } %>

    <!-- Образование -->
    <% if (doctor.education) { %>
      <div class="card border-0 shadow-sm p-4 app-card">
        <h5 class="fw-bold mb-3">
          <i class="bi bi-mortarboard text-primary me-2"></i>Образование
        </h5>
        <p class="text-secondary mb-0 lh-lg"><%= doctor.education %></p>
      </div>
    <% } %>

    <!-- Запись на приём -->
    <div class="card border-0 shadow-sm p-4 app-card" id="bookingCard">
      <h5 class="fw-bold mb-3">
        <i class="bi bi-calendar2-plus text-primary me-2"></i>Запись на приём
      </h5>

      <% if (typeof user !== 'undefined' && user && user.role === 'patient') { %>

        <!-- Календарь с доступностью -->
        <div class="mb-3">
          <label class="form-label fw-semibold d-block">
            <i class="bi bi-calendar3 me-1 text-primary"></i>Выберите дату
          </label>
          <div class="booking-cal-shell w-100">
            <div class="booking-cal card border-0 shadow-sm app-card">
              <div class="card-body p-3 p-md-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                  <button type="button" class="btn btn-outline-primary btn-sm rounded-circle booking-cal-nav" id="bcalPrev" aria-label="Предыдущий месяц">
                    <i class="bi bi-chevron-left"></i>
                  </button>
                  <span class="fw-bold text-center px-2 flex-grow-1" id="bcalTitle"></span>
                  <button type="button" class="btn btn-outline-primary btn-sm rounded-circle booking-cal-nav" id="bcalNext" aria-label="Следующий месяц">
                    <i class="bi bi-chevron-right"></i>
                  </button>
                </div>
                <div class="booking-cal-viewport position-relative" id="bcalViewport">
                  <div id="bcalLoading" class="booking-cal-loading-overlay d-none" aria-live="polite" aria-busy="true">
                    <div class="booking-cal-loading-overlay__inner text-center">
                      <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Загрузка…</span></div>
                      <p class="text-muted small mt-2 mb-0">Загрузка доступности…</p>
                    </div>
                  </div>
                  <div id="bcalGridWrap" class="booking-cal-viewport__content">
                    <div class="booking-cal-weekdays">
                      <span>Пн</span><span>Вт</span><span>Ср</span><span>Чт</span><span>Пт</span><span>Сб</span><span>Вс</span>
                    </div>
                    <div class="booking-cal-grid" id="bcalGrid"></div>
                  </div>
                </div>
                <p class="booking-cal-selected small fw-semibold text-primary mt-3 mb-0 d-none" id="bcalSelectedLabel"></p>
                <div class="booking-cal-legend small text-muted mt-3 pt-2 border-top">
                  <span class="me-3"><span class="booking-cal-legend-dot bg-cal-high"></span> много мест (5+)</span>
                  <span class="me-3"><span class="booking-cal-legend-dot bg-cal-low"></span> мало мест (1–4)</span>
                  <span><span class="booking-cal-legend-dot bg-cal-none"></span> нет мест</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="booking-slots-panel">
        <!-- Спиннер слотов -->
        <div id="slotsSpinner" class="booking-slots-panel__state text-center py-4 d-none">
          <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
          <span class="text-muted">Загрузка расписания…</span>
        </div>

        <!-- Нет слотов -->
        <div id="noSlotsMsg" class="alert alert-warning d-none booking-slots-panel__state" role="alert">
          <i class="bi bi-calendar-x me-2"></i>
          На выбранную дату нет свободного времени. Попробуйте другой день.
        </div>

        <!-- Сетка слотов -->
        <div id="slotsSection" class="d-none booking-slots-panel__state">
          <p class="form-label fw-semibold mb-2">
            <i class="bi bi-clock me-1 text-primary"></i>Выберите время
          </p>
          <div id="slotsGrid" class="slots-grid mb-3"></div>

          <!-- Форма бронирования -->
          <form id="bookingForm" method="POST" action="/appointments">
            <%- include('../partials/csrf') %>
            <input type="hidden" name="doctor_id" value="<%= doctor.id %>">
            <input type="hidden" name="date" id="hiddenDate">
            <input type="hidden" name="time" id="hiddenTime">
            <button type="submit" class="btn btn-primary px-4" id="submitBooking" disabled>
              <i class="bi bi-check-lg me-2"></i>Подтвердить запись
            </button>
          </form>
        </div>
        </div>

      <% } else if (typeof user !== 'undefined' && user && user.role !== 'patient') { %>
        <div class="alert alert-info mb-0">
          <i class="bi bi-info-circle me-2"></i>
          Записаться на приём могут только пациенты.
        </div>
      <% } else { %>
        <div class="alert alert-light border mb-3">
          <i class="bi bi-lock me-2 text-primary"></i>
          Чтобы записаться на приём, необходимо войти в систему.
        </div>
        <div class="d-flex gap-2">
          <a href="/auth/login" class="btn btn-primary px-4">
            <i class="bi bi-box-arrow-in-right me-2"></i>Войти
          </a>
          <a href="/auth/register" class="btn btn-outline-secondary px-4">Регистрация</a>
        </div>
      <% } %>
    </div>

  </div>
</div>

<% if (typeof user !== 'undefined' && user && user.role === 'patient') { %>
<script>
(function () {
  const DOCTOR_ID = parseInt('<%= doctor.id %>', 10);
  /** Только из .env APP_BASE_PATH (например /clinic). Не вычислять из pathname — ломает URL вида /X/doctors/11 → 404 */
  var API_PREFIX = <%- JSON.stringify(typeof appMountPath !== 'undefined' ? appMountPath : '') %>;
  function apiUrl(path) {
    return API_PREFIX + path;
  }
  const MONTHS_GEN = ['января','февраля','марта','апреля','мая','июня','июля','августа','сентября','октября','ноября','декабря'];
  const MONTHS_NOM = ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];

  const spinner      = document.getElementById('slotsSpinner');
  const noSlotsMsg   = document.getElementById('noSlotsMsg');
  const slotsSection = document.getElementById('slotsSection');
  const slotsGrid    = document.getElementById('slotsGrid');
  const hiddenDate   = document.getElementById('hiddenDate');
  const hiddenTime   = document.getElementById('hiddenTime');
  const submitBtn    = document.getElementById('submitBooking');

  const bcalPrev = document.getElementById('bcalPrev');
  const bcalNext = document.getElementById('bcalNext');
  const bcalTitle = document.getElementById('bcalTitle');
  const bcalLoading = document.getElementById('bcalLoading');
  const bcalViewport = document.getElementById('bcalViewport');
  const bcalGridWrap = document.getElementById('bcalGridWrap');
  const bcalGrid = document.getElementById('bcalGrid');
  const bcalSelectedLabel = document.getElementById('bcalSelectedLabel');

  let calYear, calMonth;
  let availabilityCache = {};
  let selectedDateStr = null;

  function pad2(n) { return String(n).padStart(2, '0'); }
  function toYmd(y, m1, d) { return y + '-' + pad2(m1) + '-' + pad2(d); }

  function clientTodayYmd() {
    const n = new Date();
    return toYmd(n.getFullYear(), n.getMonth() + 1, n.getDate());
  }

  function monthKey(y, m1) { return y + '-' + pad2(m1); }

  function mondayOffset(jsDowSun0) {
    return jsDowSun0 === 0 ? 6 : jsDowSun0 - 1;
  }

  async function fetchAvailability(y, m1) {
    const key = monthKey(y, m1);
    if (availabilityCache[key]) return availabilityCache[key];
    const url = apiUrl('/api/doctors/' + DOCTOR_ID + '/availability?month=' + encodeURIComponent(key));
    const res = await fetch(url);
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();
    if (!data || data.success !== true || !data.availability || typeof data.availability !== 'object') {
      throw new Error('bad payload');
    }
    availabilityCache[key] = data.availability;
    return data.availability;
  }

  function placesWordRU(n) {
    const n10 = n % 10;
    const n100 = n % 100;
    if (n100 >= 11 && n100 <= 19) return 'мест';
    if (n10 === 1) return 'место';
    if (n10 >= 2 && n10 <= 4) return 'места';
    return 'мест';
  }

  function cellClass(count, isPast) {
    if (isPast) return 'booking-cal-cell past';
    if (count >= 5) return 'booking-cal-cell high';
    if (count >= 1) return 'booking-cal-cell low';
    return 'booking-cal-cell none';
  }

  function calendarGeometry() {
    const first = new Date(calYear, calMonth - 1, 1);
    const dim = new Date(calYear, calMonth, 0).getDate();
    const startPad = mondayOffset(first.getDay());
    const totalCells = Math.ceil((startPad + dim) / 7) * 7;
    return { first, dim, startPad, totalCells };
  }

  function renderSkeletonCalendar() {
    const { dim, startPad, totalCells } = calendarGeometry();
    bcalTitle.textContent = MONTHS_NOM[calMonth - 1] + ' ' + calYear;
    bcalGrid.innerHTML = '';
    for (let i = 0; i < totalCells; i++) {
      const el = document.createElement('div');
      if (i < startPad || i >= startPad + dim) {
        el.className = 'booking-cal-skeleton-cell booking-cal-skeleton-cell--empty';
        el.setAttribute('aria-hidden', 'true');
      } else {
        el.className = 'booking-cal-skeleton-cell';
        el.setAttribute('aria-hidden', 'true');
      }
      bcalGrid.appendChild(el);
    }
  }

  function renderCalendar(avail) {
    const today = clientTodayYmd();
    const { dim, startPad, totalCells } = calendarGeometry();

    bcalTitle.textContent = MONTHS_NOM[calMonth - 1] + ' ' + calYear;
    bcalGrid.innerHTML = '';

    for (let i = 0; i < totalCells; i++) {
      const cell = document.createElement('button');
      cell.type = 'button';

      if (i < startPad || i >= startPad + dim) {
        cell.className = 'booking-cal-cell booking-cal-empty';
        cell.disabled = true;
        bcalGrid.appendChild(cell);
        continue;
      }

      const dayNum = i - startPad + 1;
      const ds = toYmd(calYear, calMonth, dayNum);
      const isPast = ds < today;
      const count = Object.prototype.hasOwnProperty.call(avail, ds) ? avail[ds] : 0;
      const clickable = !isPast && count > 0;

      cell.className = cellClass(count, isPast);
      cell.disabled = !clickable;
      cell.setAttribute('data-date', ds);
      if (ds === today) cell.classList.add('today');
      if (selectedDateStr === ds) cell.classList.add('selected');

      const mon = MONTHS_GEN[calMonth - 1];
      const placesStr = isPast ? '—' : (count + ' ' + placesWordRU(count));
      cell.innerHTML =
        '<span class="booking-cal-daynum">' + dayNum + '</span>' +
        '<span class="booking-cal-sub">' + mon + '</span>' +
        '<span class="booking-cal-badge">' + placesStr + '</span>';
      if (!isPast) {
        cell.setAttribute('title', dayNum + ' ' + mon + ' (' + count + ' ' + placesWordRU(count) + ')');
      }

      if (clickable) {
        (function (dateStr, cnt, dNum, monName) {
          cell.addEventListener('click', function () {
            onPickDate(dateStr, cnt, dNum + ' ' + monName);
          });
        })(ds, count, dayNum, mon);
      }

      bcalGrid.appendChild(cell);
    }
  }

  async function showMonth(y, m1) {
    calYear = y;
    calMonth = m1;
    renderSkeletonCalendar();
    if (bcalViewport) bcalViewport.classList.add('is-loading');
    bcalLoading.classList.remove('d-none');
    try {
      const avail = await fetchAvailability(y, m1);
      renderCalendar(avail);
    } catch (e) {
      bcalTitle.textContent = 'Ошибка загрузки';
      renderCalendar({});
      console.error('Календарь: не удалось загрузить доступность', e);
    } finally {
      bcalLoading.classList.add('d-none');
      if (bcalViewport) bcalViewport.classList.remove('is-loading');
    }
  }

  function onPickDate(ds, count, dayHuman) {
    selectedDateStr = ds;
    hiddenDate.value = ds;
    hiddenTime.value = '';
    submitBtn.disabled = true;
    bcalSelectedLabel.textContent = 'Выбрано: ' + dayHuman + ' (' + count + ' ' + placesWordRU(count) + ')';
    bcalSelectedLabel.classList.remove('d-none');
    document.querySelectorAll('.booking-cal-cell[data-date]').forEach(function (el) {
      el.classList.toggle('selected', el.getAttribute('data-date') === selectedDateStr);
    });
    loadSlotsForDate(ds);
  }

  async function loadSlotsForDate(date) {
    slotsSection.classList.add('d-none');
    noSlotsMsg.classList.add('d-none');
    spinner.classList.remove('d-none');
    if (slotsGrid) slotsGrid.classList.add('slots-grid--loading');

    try {
      const res = await fetch(apiUrl('/api/doctors/' + DOCTOR_ID + '/slots?date=' + encodeURIComponent(date)));
      if (!res.ok) throw new Error('Server error');
      const data = await res.json();
      if (!data || data.success !== true || !Array.isArray(data.slots)) throw new Error('Bad payload');
      renderSlots(data.slots, date);
    } catch (e) {
      noSlotsMsg.textContent = 'Ошибка загрузки расписания. Попробуйте позже.';
      noSlotsMsg.classList.remove('d-none');
    } finally {
      spinner.classList.add('d-none');
      if (slotsGrid) slotsGrid.classList.remove('slots-grid--loading');
    }
  }

  function renderSlots(slots, date) {
    if (!slots || slots.length === 0) {
      noSlotsMsg.classList.remove('d-none');
      return;
    }

    slotsGrid.innerHTML = '';
    slots.forEach(function (slot) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'btn btn-outline-primary slot-btn';
      btn.textContent = slot;
      btn.addEventListener('click', function () {
        document.querySelectorAll('.slot-btn').forEach(function (b) {
          b.classList.remove('active', 'btn-primary');
          b.classList.add('btn-outline-primary');
        });
        btn.classList.add('active', 'btn-primary');
        btn.classList.remove('btn-outline-primary');
        hiddenDate.value = date;
        hiddenTime.value = slot;
        submitBtn.disabled = false;
      });
      slotsGrid.appendChild(btn);
    });

    slotsSection.classList.remove('d-none');
  }

  const now = new Date();
  calYear = now.getFullYear();
  calMonth = now.getMonth() + 1;

  bcalPrev.addEventListener('click', function (e) {
    e.preventDefault();
    e.stopPropagation();
    calMonth--;
    if (calMonth < 1) { calMonth = 12; calYear--; }
    showMonth(calYear, calMonth);
  });
  bcalNext.addEventListener('click', function (e) {
    e.preventDefault();
    e.stopPropagation();
    calMonth++;
    if (calMonth > 12) { calMonth = 1; calYear++; }
    showMonth(calYear, calMonth);
  });

  showMonth(calYear, calMonth);

  document.getElementById('bookingForm').addEventListener('submit', function () {
    availabilityCache = {};
  });
})();
</script>
<% } %>

<%- include('../partials/footer') %>
