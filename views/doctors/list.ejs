<%
function experienceLabel(n) {
  if (n % 100 >= 11 && n % 100 <= 19) return 'лет';
  switch (n % 10) {
    case 1: return 'год';
    case 2: case 3: case 4: return 'года';
    default: return 'лет';
  }
}
%>
<%- include('../partials/header', { title: title, loadChoicesCss: typeof loadChoicesCss !== 'undefined' && loadChoicesCss }) %>
<% var dsTitle = 'Каталог врачей'; var dsSubtitle = 'Поиск по ФИО и специализации. Найдено: ' + doctors.length + ' специалистов'; var dsIcon = 'bi-person-badge'; %>
<%- include('../partials/ds-page-header') %>

<div class="filter-panel app-card border-0 shadow-sm mb-4">
  <div class="card-body p-3 p-md-4">
    <form method="GET" action="/doctors" class="row g-3 align-items-end">

      <div class="col-md-5">
        <label for="search" class="form-label fw-semibold small text-muted text-uppercase letter-spacing-wide">
          <i class="bi bi-search me-1"></i>Поиск по ФИО
        </label>
        <input
          type="text"
          class="form-control"
          id="search"
          name="search"
          value="<%= filters.search %>"
          placeholder="Введите фамилию, имя или отчество..."
        />
      </div>

      <div class="col-md-4">
        <label for="specialization_id" class="form-label fw-semibold small text-muted text-uppercase letter-spacing-wide">
          <i class="bi bi-funnel me-1"></i>Специализация
        </label>
        <select class="form-select choices-catalog-spec" id="specialization_id" name="specialization_id">
          <option value="">— Все специальности —</option>
          <% specializations.forEach(s => { %>
            <option value="<%= s.id %>" <%= filters.specialization_id == s.id ? 'selected' : '' %>>
              <%= s.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="col-md-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary flex-fill rounded-pill">
          <i class="bi bi-search me-1"></i>Найти
        </button>
        <% if (filters.search || filters.specialization_id) { %>
          <a href="/doctors" class="btn btn-outline-secondary" title="Сбросить фильтры">
            <i class="bi bi-x-lg"></i>
          </a>
        <% } %>
      </div>

    </form>
  </div>
</div>

<!-- Список врачей -->
<% if (doctors.length === 0) { %>
  <div class="empty-state text-center app-card p-5">
    <div class="empty-state__icon text-muted mb-3"><i class="bi bi-search"></i></div>
    <h5 class="text-muted fw-semibold">Врачи не найдены</h5>
    <p class="text-muted small mb-3">Попробуйте изменить параметры поиска</p>
    <a href="/doctors" class="btn btn-outline-primary btn-sm rounded-pill">
      <i class="bi bi-arrow-counterclockwise me-1"></i>Сбросить фильтры
    </a>
  </div>

<% } else { %>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% doctors.forEach(doctor => { %>
      <div class="col">
        <div class="doctor-card card h-100 border-0 shadow-sm">

          <!-- Аватар и специализация -->
          <div class="doctor-card-header text-center pt-4 pb-2">
            <div class="doctor-card-avatar-wrap mx-auto mb-3">
              <%- include('../partials/user-avatar', { person: doctor, size: 'card' }) %>
            </div>
            <% const specs = Array.isArray(doctor.specializations) ? doctor.specializations : []; %>
            <% if (specs.length) { %>
              <div class="d-flex flex-wrap justify-content-center gap-1 px-2 doctor-spec-badges" title="<%= specs.map(function(x){return x.name;}).join(', ') %>">
                <% const show = 3; %>
                <% specs.slice(0, show).forEach(function(sp) { %>
                  <span class="badge spec-badge<%= sp.is_primary ? '' : ' bg-light text-dark border' %>"><%= sp.name %></span>
                <% }); %>
                <% if (specs.length > show) { %>
                  <span class="badge bg-secondary">+<%= specs.length - show %></span>
                <% } %>
              </div>
            <% } %>
          </div>

          <div class="card-body pt-2">
            <h5 class="card-title text-center fw-bold mb-3">
              <%= doctor.last_name %> <%= doctor.first_name %> <%= doctor.middle_name %>
            </h5>

            <ul class="doctor-meta list-unstyled mb-3">
              <% if (doctor.cabinet) { %>
                <li>
                  <i class="bi bi-door-open text-primary"></i>
                  <span>Кабинет № <%= doctor.cabinet %></span>
                </li>
              <% } %>
              <% if (doctor.experience_years > 0) { %>
                <li>
                  <i class="bi bi-award text-primary"></i>
                  <span>Стаж: <strong><%= doctor.experience_years %> <%= experienceLabel(doctor.experience_years) %></strong></span>
                </li>
              <% } %>
            </ul>

            <% if (doctor.description) { %>
              <p class="card-text text-muted small description-preview">
                <%= doctor.description.length > 120 ? doctor.description.substring(0, 120) + '...' : doctor.description %>
              </p>
            <% } %>
          </div>

          <div class="card-footer bg-transparent border-0 pb-4 px-3">
            <a href="/doctors/<%= doctor.id %>" class="btn btn-outline-primary w-100">
              <i class="bi bi-person-lines-fill me-1"></i>Подробнее
            </a>
          </div>

        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/footer') %>
