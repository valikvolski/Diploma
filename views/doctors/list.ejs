<%
  function experienceLabel(n) {
    if (!n) return 'лет';
    if (n % 100 >= 11 && n % 100 <= 19) return 'лет';
    switch (n % 10) {
      case 1: return 'год';
      case 2: case 3: case 4: return 'года';
      default: return 'лет';
    }
  }
  function doctorFullName(d) {
    return [d.last_name, d.first_name, d.middle_name || ''].join(' ').trim();
  }
  function avatarSrc(d) {
    if (d.avatar_path) return '/' + String(d.avatar_path).replace(/^\/+/, '');
    if (d.avatar_url) return String(d.avatar_url);
    return '';
  }
  function initials(d) {
    var l = String(d.last_name || '').trim();
    var f = String(d.first_name || '').trim();
    return ((l ? l.charAt(0) : '') + (f ? f.charAt(0) : '')).toUpperCase() || '?';
  }
  var selectedSpec = String(filters && filters.specialization_id ? filters.specialization_id : '');
  var selectedSpecName = typeof selectedSpecializationName !== 'undefined' ? selectedSpecializationName : null;
  var popularSpecs = (specializations || []).slice(0, 12);
  var isSelectedInPopular = selectedSpec && popularSpecs.some(function(s){ return String(s.id) === selectedSpec; });
  var specsExpandedByDefault = selectedSpec && !isSelectedInPopular;
  function stateQuery(page) {
    var qp = new URLSearchParams();
    if (filters && filters.search) qp.set('search', String(filters.search));
    if (selectedSpec) qp.set('specialization_id', selectedSpec);
    if (page && page > 1) qp.set('page', String(page));
    var s = qp.toString();
    return s ? ('?' + s) : '';
  }
%>
<%- include('../partials/header', { title: title }) %>
<% var dsTitle = 'Каталог врачей'; var dsSubtitle = 'Выберите специализацию, затем врача'; var dsIcon = 'bi-person-badge'; %>
<%- include('../partials/ds-page-header') %>

<div class="app-card border-0 shadow-sm mb-4">
  <div class="card-body p-3 p-md-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
      <h2 class="h6 fw-bold text-uppercase text-muted mb-0"><i class="bi bi-grid me-2"></i>Специализации</h2>
      <div class="small text-muted">Найдено врачей: <span id="catalog-total-count"><%= pagination.totalCount || 0 %></span></div>
    </div>
    <div id="catalog-spec-root">
    <div id="catalog-spec-list-wrap" class="<%= specsExpandedByDefault ? 'is-expanded' : '' %>">
    <div class="d-flex flex-wrap gap-2 mb-1" id="catalog-spec-list">
      <a href="/doctors<%= stateQuery(1) %>" class="btn btn-sm <%= !selectedSpec ? 'btn-primary' : 'btn-outline-primary' %> rounded-pill js-spec-filter" data-spec-id="">
        Все врачи
      </a>
      <% (specializations || []).forEach(function(s) { %>
        <a href="/doctors?<%= new URLSearchParams(Object.assign({}, filters.search ? { search: filters.search } : {}, { specialization_id: String(s.id) })).toString() %>"
           class="btn btn-sm <%= selectedSpec === String(s.id) ? 'btn-primary' : 'btn-outline-primary' %> rounded-pill js-spec-filter"
           data-spec-id="<%= s.id %>">
          <%= s.name %> <span class="opacity-75">(<%= s.doctor_count || 0 %>)</span>
        </a>
      <% }) %>
      <% if ((specializations || []).length > 12) { %>
        <button id="catalog-toggle-all-specs" class="btn btn-sm btn-outline-secondary rounded-pill js-spec-toggle-chip" type="button" aria-expanded="<%= specsExpandedByDefault ? 'true' : 'false' %>">
          <%= specsExpandedByDefault ? 'Свернуть' : 'Показать еще' %>
        </button>
      <% } %>
    </div>
    </div>
    </div>
    <form id="catalog-search-form" method="GET" action="/doctors" class="row g-2 align-items-end">
      <% if (selectedSpec) { %><input type="hidden" name="specialization_id" value="<%= selectedSpec %>"><% } %>
      <div class="col-12 col-md-8 col-lg-6">
        <label for="catalog-search" class="form-label small fw-semibold text-muted">Поиск врача</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <input type="text" id="catalog-search" name="search" class="form-control" value="<%= filters.search || '' %>" placeholder="Фамилия, имя или отчество">
        </div>
      </div>
      <div class="col-12 col-md-4 col-lg-2">
        <button type="submit" class="btn btn-primary w-100">Найти</button>
      </div>
    </form>
  </div>
</div>

<div class="d-flex align-items-center justify-content-between gap-2 mb-3">
  <h2 class="h6 fw-bold text-uppercase text-muted mb-0"><i class="bi bi-people me-2"></i>Врачи</h2>
  <div class="small text-muted">Стр. <span id="catalog-page-indicator"><%= pagination.page %> / <%= pagination.totalPages %></span></div>
</div>

<div id="catalog-loading" class="d-none text-center py-3">
  <div class="spinner-border spinner-border-sm text-primary me-2" role="status" aria-hidden="true"></div>
  <span class="small text-muted">Загружаем врачей...</span>
</div>

<div id="catalog-doctors-grid" class="row g-3" data-page="<%= pagination.page %>" data-total-pages="<%= pagination.totalPages %>">
  <% if (!doctors || !doctors.length) { %>
    <div class="col-12">
      <div class="text-center app-card p-5">
        <div class="empty-state__icon text-muted mb-3"><i class="bi bi-search"></i></div>
        <h5 class="text-muted fw-semibold">Врачи не найдены</h5>
        <p class="text-muted small mb-0">Попробуйте изменить фильтры</p>
      </div>
    </div>
  <% } %>
  <% (doctors || []).forEach(function(doctor){ %>
    <div class="col-12 col-md-6 col-lg-4 col-xl-3">
      <article class="card h-100 border-0 shadow-sm doctor-catalog-card">
        <div class="card-body p-3 d-flex flex-column">
          <div class="d-flex align-items-start gap-2 mb-2 min-w-0">
            <div class="flex-shrink-0">
              <% if (avatarSrc(doctor)) { %>
                <img src="<%= avatarSrc(doctor) %>" alt="" class="rounded-circle border" width="46" height="46" loading="lazy" style="object-fit: cover;">
              <% } else { %>
                <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-semibold" style="width:46px;height:46px;background:linear-gradient(135deg,#2c7be5,#4f46e5);"><%= initials(doctor) %></div>
              <% } %>
            </div>
            <div class="min-w-0 flex-grow-1">
              <h3 class="h6 mb-1 doctor-tile-name"><%= doctorFullName(doctor) %></h3>
              <div class="d-flex align-items-center gap-1 min-w-0">
                <span class="badge spec-badge text-truncate d-inline-block" style="max-width: 100%;"><%= selectedSpecName || doctor.primary_specialization || 'Специализация не указана' %></span>
                <% if ((doctor.extra_specializations_count || 0) > 0) { %>
                  <span class="badge bg-light text-muted border flex-shrink-0">+<%= doctor.extra_specializations_count %></span>
                <% } %>
              </div>
            </div>
          </div>
          <div class="small text-muted mb-3">
            <% if (doctor.experience_years > 0) { %>Стаж: <%= doctor.experience_years %> <%= experienceLabel(doctor.experience_years) %><% } else { %>Стаж не указан<% } %>
            <% if (doctor.cabinet) { %><span class="ms-2">Каб. <%= doctor.cabinet %></span><% } %>
          </div>
          <div class="mt-auto">
            <a href="/doctors/<%= doctor.id %>" class="btn btn-outline-primary btn-sm rounded-pill w-100">Записаться</a>
          </div>
        </div>
      </article>
    </div>
  <% }) %>
</div>

<div class="text-center mt-4">
  <button id="catalog-load-more" type="button" class="btn btn-outline-primary px-4" <%= pagination.hasNext ? '' : 'hidden' %>>
    Показать ещё
  </button>
</div>

<script>
  window.__DOCTORS_CATALOG_STATE__ = {
    search: <%- JSON.stringify(filters.search || '') %>,
    specialization_id: <%- JSON.stringify(filters.specialization_id || '') %>,
    selectedSpecializationName: <%- JSON.stringify(selectedSpecName || '') %>,
    page: <%= pagination.page || 1 %>,
    totalPages: <%= pagination.totalPages || 1 %>
  };
</script>
<script src="/js/doctors-catalog-dynamic.js"></script>

<%- include('../partials/footer') %>
