<%- include('../partials/header', { title: title }) %>
<% var dsTitle = 'Профиль пациента'; var dsSubtitle = 'ФИО, телефон и дата рождения'; var dsIcon = 'bi-person'; var dsBackHref = '/profile/appointments'; var dsBackLabel = 'К моим записям'; %>
<%- include('../partials/ds-page-header') %>
<% var birthDateMax = new Date().toISOString().slice(0, 10); %>

<div class="row justify-content-center profile-edit-page">
  <div class="col-lg-8">
    <div class="auth-card ds-auth-card card border-0 mx-auto" style="max-width: 640px;">
      <div class="card-body p-4 p-md-5">

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
            <span><%= error %></span>
          </div>
        <% } %>
        <% if (typeof flashSuccess !== 'undefined' && flashSuccess) { %>
          <div class="alert alert-success d-flex align-items-start gap-2" role="alert">
            <i class="bi bi-check-circle-fill flex-shrink-0 mt-1"></i>
            <span><%= flashSuccess %></span>
          </div>
        <% } %>
        <% if (typeof flashError !== 'undefined' && flashError) { %>
          <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
            <span><%= flashError %></span>
          </div>
        <% } %>

        <% if (typeof profileWarningBanner !== 'undefined' && profileWarningBanner) { %>
          <div class="alert alert-warning d-flex align-items-start gap-2" role="alert">
            <i class="bi bi-telephone-fill flex-shrink-0 mt-1"></i>
            <span><%= profileWarningMessage || 'Перед записью необходимо заполнить профиль.' %></span>
          </div>
        <% } %>

        <% if (typeof avatarUser !== 'undefined' && avatarUser) { %>
        <div class="profile-avatar-panel app-card border-0 shadow-sm p-3 p-md-4 mb-4">
          <h2 class="h6 fw-bold mb-3">Фото профиля</h2>
          <div class="d-flex flex-column flex-md-row align-items-stretch align-items-md-start gap-3 gap-md-4">
            <div
              class="profile-avatar-preview-wrap text-center text-md-start flex-shrink-0 position-relative"
              data-profile-avatar-upload
            >
              <button
                type="button"
                class="btn btn-link p-0 border-0 profile-avatar-change-hitarea text-decoration-none"
                id="profileAvatarChangeTrigger"
                aria-label="Сменить фото профиля"
              >
                <span class="d-inline-block position-relative">
                  <%- include('../partials/user-avatar', { person: avatarUser, size: 'profile' }) %>
                  <span
                    class="profile-avatar-upload-spinner position-absolute top-50 start-50 translate-middle d-none"
                    role="status"
                    aria-live="polite"
                    aria-label="Загрузка"
                  >
                    <span class="spinner-border spinner-border-sm text-primary" aria-hidden="true"></span>
                  </span>
                </span>
              </button>
              <input
                type="file"
                id="profileAvatarFile"
                name="avatar"
                class="d-none"
                accept="image/jpeg,image/png,image/webp,.jpg,.jpeg,.png,.webp"
                autocomplete="off"
                aria-hidden="true"
                tabindex="-1"
              />
            </div>
            <div class="flex-grow-1 w-100 d-flex flex-column justify-content-center" style="min-width: 0;">
              <div class="d-flex flex-wrap align-items-center gap-2">
                <button type="button" class="btn btn-primary btn-sm rounded-pill mb-0" id="profileAvatarChangeBtn">
                  <i class="bi bi-camera me-1"></i>Сменить фото
                </button>
                <button
                  type="button"
                  class="btn btn-link btn-sm text-body-secondary p-1 rounded-circle profile-avatar-info-btn"
                  id="avatarUploadHint"
                  data-bs-toggle="tooltip"
                  data-bs-placement="top"
                  data-bs-title="Допустимые форматы: JPG, PNG, WebP. Максимум 2 МБ. Фото будет обрезано до квадрата."
                  aria-label="Справка по загрузке фото"
                >
                  <i class="bi bi-info-circle fs-5" aria-hidden="true"></i>
                </button>
                <% if (avatarUser.avatar_path) { %>
                <form method="POST" action="/profile/avatar/remove" class="d-inline mb-0" onsubmit="return confirm('Удалить фото профиля?');">
                  <%- include('../partials/csrf') %>
                  <button type="submit" class="btn btn-outline-secondary btn-sm rounded-pill"><i class="bi bi-trash me-1"></i>Удалить</button>
                </form>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        <% } %>

        <div class="app-card border-0 shadow-sm p-3 p-md-4 mb-4 profile-security-card">
          <h2 class="h6 fw-bold mb-3"><i class="bi bi-shield-lock text-primary me-2"></i>Безопасность</h2>
          <p class="small text-muted mb-3 mb-md-0">Смена пароля подтверждается кодом из письма на ваш адрес <strong class="text-body"><%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %></strong>.</p>
          <button type="button" class="btn btn-outline-primary btn-sm rounded-pill" data-bs-toggle="modal" data-bs-target="#changePasswordModal">
            <i class="bi bi-key me-1"></i>Изменить пароль
          </button>
        </div>

        <form method="POST" action="/profile/edit" novalidate>
          <%- include('../partials/csrf') %>

          <div class="mb-3">
            <label class="form-label fw-semibold">Электронная почта</label>
            <input type="email" class="form-control" value="<%= formData.email %>" disabled />
            <div class="form-text text-muted">Адрес почты нельзя изменить</div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label for="last_name" class="form-label fw-semibold">Фамилия</label>
              <input type="text" class="form-control" id="last_name" name="last_name"
                value="<%= formData.last_name %>" required />
            </div>
            <div class="col-md-6">
              <label for="first_name" class="form-label fw-semibold">Имя</label>
              <input type="text" class="form-control" id="first_name" name="first_name"
                value="<%= formData.first_name %>" required />
            </div>
          </div>

          <div class="mb-3">
            <label for="middle_name" class="form-label fw-semibold">Отчество</label>
            <input type="text" class="form-control" id="middle_name" name="middle_name"
              value="<%= formData.middle_name %>" required />
          </div>

          <div class="mb-3">
            <label for="gender" class="form-label fw-semibold">Пол</label>
            <select class="form-select" id="gender" name="gender">
              <option value="">— не указано —</option>
              <option value="male" <%= formData.gender === 'male' ? 'selected' : '' %>>Мужской</option>
              <option value="female" <%= formData.gender === 'female' ? 'selected' : '' %>>Женский</option>
            </select>
          </div>

          <div class="mb-3">
            <label for="address" class="form-label fw-semibold">Адрес</label>
            <textarea class="form-control" id="address" name="address" rows="2" placeholder="Необязательно"><%= formData.address || '' %></textarea>
          </div>

          <%- include('../partials/phone-international-field', {
            phoneFieldId: 'phone',
            phoneValue: formData.phone,
            phoneRequired: true
          }) %>

          <div class="mb-4 profile-birth-field">
            <label for="birth_date" class="form-label fw-semibold">Дата рождения</label>
            <%- include('../partials/birth-date-field', {
              id: 'birth_date',
              name: 'birth_date',
              value: formData.birth_date,
              min: '1900-01-01',
              max: birthDateMax,
              required: false,
              readonly: !canEditBirthDate,
              editableHelpText: 'Укажите дату рождения для завершения профиля.',
              helpText: 'Дата рождения не может быть изменена.'
            }) %>
          </div>

          <button type="submit" class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-check-lg me-2"></i>Сохранить изменения
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="changePasswordModal" tabindex="-1" aria-labelledby="changePasswordModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold" id="changePasswordModalLabel">Смена пароля</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
      </div>
      <div class="modal-body">
        <div id="pwChangeStepA">
          <p class="small mb-3">Для смены пароля подтвердите действие кодом из письма.</p>
          <button type="button" class="btn btn-primary w-100 rounded-pill" id="pwChangeSendCode">
            <span class="pw-change-btn-label"><i class="bi bi-envelope me-2"></i>Отправить код на почту</span>
            <span class="pw-change-btn-spinner d-none spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
            <span class="pw-change-btn-loading d-none">Отправка…</span>
          </button>
          <p class="small text-success mt-3 mb-0 d-none" id="pwChangeCodeSent"><i class="bi bi-check-circle me-1"></i>Код отправлен. Проверьте почту.</p>
          <p class="small text-danger mt-2 mb-0 d-none" id="pwChangeStepAError"></p>
        </div>
        <div id="pwChangeStepB" class="d-none">
          <div class="mb-3">
            <label class="form-label fw-semibold" for="pwChangeCode">Код из письма</label>
            <input type="text" class="form-control" id="pwChangeCode" inputmode="numeric" maxlength="12" placeholder="000000" autocomplete="one-time-code" />
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold" for="pwChangeNew">Новый пароль</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text"><i class="bi bi-key"></i></span>
              <input type="password" class="form-control" id="pwChangeNew" minlength="6" autocomplete="new-password" />
              <button class="btn btn-outline-secondary" type="button" id="pwChangeToggle1" aria-label="Показать пароль"><i class="bi bi-eye"></i></button>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold" for="pwChangeNew2">Подтверждение</label>
            <div class="input-group ds-input-group">
              <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
              <input type="password" class="form-control" id="pwChangeNew2" minlength="6" autocomplete="new-password" />
              <button class="btn btn-outline-secondary" type="button" id="pwChangeToggle2" aria-label="Показать пароль"><i class="bi bi-eye"></i></button>
            </div>
          </div>
          <p class="small text-danger mb-3 d-none" id="pwChangeStepBError"></p>
          <button type="button" class="btn btn-danger w-100 rounded-pill" id="pwChangeSubmit">
            <span class="pw-change-submit-label"><i class="bi bi-check-lg me-2"></i>Сменить пароль</span>
            <span class="pw-change-submit-spinner d-none spinner-border spinner-border-sm me-2"></span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/phone-international.js"></script>
<script src="/js/auth-forms.js"></script>
<script src="/js/profile-password-modal.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  var hint = document.getElementById('avatarUploadHint');
  if (hint && typeof bootstrap !== 'undefined' && bootstrap.Tooltip) {
    new bootstrap.Tooltip(hint, { container: 'body' });
  }
  var file = document.getElementById('profileAvatarFile');
  var btn = document.getElementById('profileAvatarChangeBtn');
  var hit = document.getElementById('profileAvatarChangeTrigger');
  function pick() {
    if (file) file.click();
  }
  if (btn && file) btn.addEventListener('click', pick);
  if (hit && file) {
    hit.addEventListener('click', function (e) {
      e.preventDefault();
      pick();
    });
  }
});
</script>
<%- include('../partials/footer') %>
<script src="/js/profile-avatar-auto.js"></script>
