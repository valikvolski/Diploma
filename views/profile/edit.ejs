<%- include('../partials/header', { title: title }) %>

<div class="mb-4">
  <a href="/profile/appointments" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>К моим записям
  </a>
</div>

<div class="auth-wrapper">
  <div class="auth-card card shadow-sm" style="max-width:520px">
    <div class="card-body p-4 p-md-5">

      <div class="text-center mb-4">
        <div class="auth-icon mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="#0d6efd" viewBox="0 0 16 16">
            <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5z"/>
          </svg>
        </div>
        <h4 class="fw-bold text-dark">Редактировать профиль</h4>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <form method="POST" action="/profile/edit" novalidate>

        <div class="mb-3">
          <label class="form-label fw-semibold">Электронная почта</label>
          <input type="email" class="form-control" value="<%= formData.email %>" disabled />
          <div class="form-text text-muted">Email изменить нельзя</div>
        </div>

        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <label for="last_name" class="form-label fw-semibold">Фамилия</label>
            <input type="text" class="form-control" id="last_name" name="last_name"
              value="<%= formData.last_name %>" required />
          </div>
          <div class="col-md-6">
            <label for="first_name" class="form-label fw-semibold">Имя</label>
            <input type="text" class="form-control" id="first_name" name="first_name"
              value="<%= formData.first_name %>" required />
          </div>
        </div>

        <div class="mb-3">
          <label for="middle_name" class="form-label fw-semibold">Отчество</label>
          <input type="text" class="form-control" id="middle_name" name="middle_name"
            value="<%= formData.middle_name %>" required />
        </div>

        <div class="mb-3">
          <label for="phone" class="form-label fw-semibold">Телефон</label>
          <input type="tel" class="form-control" id="phone" name="phone"
            value="<%= formData.phone %>" required pattern="\+375[0-9]{9}" maxlength="13" />
          <div class="form-text text-muted">Формат: +375XXXXXXXXX</div>
        </div>

        <hr class="my-3">
        <p class="text-muted small mb-3">Дополнительная информация (необязательно)</p>

        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <label for="birth_date" class="form-label fw-semibold">Дата рождения</label>
            <input type="date" class="form-control" id="birth_date" name="birth_date" data-unified-calendar="1"
              value="<%= formData.birth_date %>" max="<%= new Date().toISOString().split('T')[0] %>" />
          </div>
          <div class="col-md-6">
            <label for="gender" class="form-label fw-semibold">Пол</label>
            <select class="form-select" id="gender" name="gender">
              <option value="">— Не указан —</option>
              <option value="male" <%= formData.gender === 'male' ? 'selected' : '' %>>Мужской</option>
              <option value="female" <%= formData.gender === 'female' ? 'selected' : '' %>>Женский</option>
            </select>
          </div>
        </div>

        <div class="mb-4">
          <label for="address" class="form-label fw-semibold">Адрес</label>
          <textarea class="form-control" id="address" name="address" rows="2"
            placeholder="Город, улица, дом, квартира"><%= formData.address %></textarea>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary flex-fill py-2 fw-semibold">
            <i class="bi bi-check-lg me-1"></i>Сохранить изменения
          </button>
          <a href="/profile/appointments" class="btn btn-outline-secondary py-2 px-4">Отмена</a>
        </div>

      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
