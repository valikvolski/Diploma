<%
const MONTHS = ['января','февраля','марта','апреля','мая','июня',
                'июля','августа','сентября','октября','ноября','декабря'];
function formatDate(str) {
  if (!str) return '—';
  const p = String(str).substring(0,10).split('-');
  return `${parseInt(p[2],10)} ${MONTHS[parseInt(p[1],10)-1]} ${p[0]} г.`;
}
function statusBadge(s) {
  switch(s) {
    case 'booked':    return '<span class="status-pill status-pill--booked"><i class="bi bi-check-circle"></i>Забронировано</span>';
    case 'cancelled': return '<span class="status-pill status-pill--cancelled"><i class="bi bi-x-circle"></i>Отменено</span>';
    case 'completed': return '<span class="status-pill status-pill--completed"><i class="bi bi-check2-all"></i>Завершено</span>';
    default:          return '<span class="status-pill status-pill--cancelled">' + s + '</span>';
  }
}
%>
<%- include('../partials/header', { title: title }) %>
<% var dsTitle = 'Мои записи'; var dsSubtitle = 'Предстоящие и прошедшие приёмы, талоны и отмена записи'; var dsIcon = 'bi-journal-text'; var dsActions = '<a href="/profile/edit" class="btn btn-outline-secondary btn-sm rounded-pill"><i class="bi bi-pencil me-1"></i>Профиль</a><a href="/doctors" class="btn btn-primary btn-sm rounded-pill"><i class="bi bi-plus-circle me-1"></i>Новая запись</a>'; %>
<%- include('../partials/ds-page-header') %>

<% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i><%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<!-- Навигационные табы -->
<ul class="nav nav-tabs mb-4" role="tablist">
  <li class="nav-item">
    <button class="nav-link active fw-semibold" data-bs-toggle="tab" data-bs-target="#upcoming" type="button">
      <i class="bi bi-calendar-check me-1"></i>Предстоящие
      <% if (upcoming.length) { %>
        <span class="badge bg-primary ms-1"><%= upcoming.length %></span>
      <% } %>
    </button>
  </li>
  <li class="nav-item">
    <button class="nav-link fw-semibold" data-bs-toggle="tab" data-bs-target="#pastTab" type="button">
      <i class="bi bi-clock-history me-1"></i>Прошедшие
      <% if (past.length) { %>
        <span class="badge bg-secondary ms-1"><%= past.length %></span>
      <% } %>
    </button>
  </li>
</ul>

<div class="tab-content">

  <!-- Предстоящие -->
  <div class="tab-pane fade show active" id="upcoming">
    <% if (upcoming.length === 0) { %>
      <div class="empty-state text-center">
        <div class="empty-state__icon text-muted"><i class="bi bi-calendar-x"></i></div>
        <p class="text-muted fw-semibold mt-2">У вас нет предстоящих записей</p>
        <a href="/doctors" class="btn btn-primary btn-sm rounded-pill mt-2">
          <i class="bi bi-search me-1"></i>Найти врача
        </a>
      </div>
    <% } else { %>
      <div class="row row-cols-1 row-cols-md-2 g-3">
        <% upcoming.forEach(function(a) { %>
          <div class="col">
            <div class="appointment-card card border-0 shadow-sm h-100 app-card">
              <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <div>
                    <h6 class="fw-bold mb-0">
                      <%= a.doctor_last_name %> <%= a.doctor_first_name[0] %>.<%= a.doctor_middle_name[0] %>.
                    </h6>
                    <% if (a.specialization) { %>
                      <span class="badge spec-badge mt-1"><%= a.specialization %></span>
                    <% } %>
                  </div>
                  <%- statusBadge(a.status) %>
                </div>

                <div class="d-flex flex-wrap gap-3 text-muted small mt-3 mb-3">
                  <span><i class="bi bi-calendar3 text-primary me-1"></i><%= formatDate(a.appointment_date) %></span>
                  <span><i class="bi bi-clock text-primary me-1"></i><%= a.appointment_time %></span>
                  <% if (a.cabinet) { %>
                    <span><i class="bi bi-door-open text-primary me-1"></i>Каб. <%= a.cabinet %></span>
                  <% } %>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                  <% if (a.ticket_id) { %>
                    <a href="/tickets/<%= a.ticket_id %>" class="btn btn-outline-primary btn-sm">
                      <i class="bi bi-ticket-perforated me-1"></i>Талон
                    </a>
                  <% } %>
                  <button
                    type="button"
                    class="btn btn-outline-danger btn-sm cancel-btn"
                    data-id="<%= a.appointment_id %>"
                    data-doctor="<%= a.doctor_last_name %> <%= a.doctor_first_name[0] %>.<%= a.doctor_middle_name[0] %>."
                    data-date="<%= formatDate(a.appointment_date) %>"
                    data-time="<%= a.appointment_time %>"
                  >
                    <i class="bi bi-x-lg me-1"></i>Отменить
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Прошедшие -->
  <div class="tab-pane fade" id="pastTab">
    <% if (past.length === 0) { %>
      <div class="empty-state text-center">
        <div class="empty-state__icon text-muted"><i class="bi bi-clock-history"></i></div>
        <p class="text-muted fw-semibold mt-2">Нет прошедших записей</p>
      </div>
    <% } else { %>
      <div class="row row-cols-1 row-cols-md-2 g-3">
        <% past.forEach(function(a) { %>
          <div class="col">
            <div class="appointment-card card border-0 shadow-sm h-100 app-card <%= a.status === 'cancelled' ? 'opacity-65' : '' %>">
              <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <div>
                    <h6 class="fw-bold mb-0">
                      <%= a.doctor_last_name %> <%= a.doctor_first_name[0] %>.<%= a.doctor_middle_name[0] %>.
                    </h6>
                    <% if (a.specialization) { %>
                      <span class="badge spec-badge mt-1"><%= a.specialization %></span>
                    <% } %>
                  </div>
                  <%- statusBadge(a.status) %>
                </div>

                <div class="d-flex flex-wrap gap-3 text-muted small mt-3 mb-3">
                  <span><i class="bi bi-calendar3 text-primary me-1"></i><%= formatDate(a.appointment_date) %></span>
                  <span><i class="bi bi-clock text-primary me-1"></i><%= a.appointment_time %></span>
                  <% if (a.cabinet) { %>
                    <span><i class="bi bi-door-open text-primary me-1"></i>Каб. <%= a.cabinet %></span>
                  <% } %>
                </div>

                <% if (a.ticket_id) { %>
                  <a href="/tickets/<%= a.ticket_id %>" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-ticket-perforated me-1"></i>Посмотреть талон
                  </a>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

</div>

<!-- Модальное окно подтверждения отмены -->
<div class="modal fade" id="cancelModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold">Отмена записи</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="mb-3">Вы уверены, что хотите отменить запись?</p>
        <div class="app-modal-detail-card small mb-0">
          <strong>Врач:</strong> <span id="cancelDoctor"></span><br>
          <strong>Дата:</strong> <span id="cancelDate"></span><br>
          <strong>Время:</strong> <span id="cancelTime"></span>
        </div>
      </div>
      <div class="modal-footer border-0 gap-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
        <form id="cancelForm" method="POST" class="d-inline">
          <%- include('../partials/csrf') %>
          <button type="submit" class="btn btn-danger">
            <i class="bi bi-x-lg me-1"></i>Отменить запись
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.cancel-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.getElementById('cancelDoctor').textContent = this.dataset.doctor;
    document.getElementById('cancelDate').textContent   = this.dataset.date;
    document.getElementById('cancelTime').textContent   = this.dataset.time;
    document.getElementById('cancelForm').action = '/profile/appointments/' + this.dataset.id + '/cancel';
    new bootstrap.Modal(document.getElementById('cancelModal')).show();
  });
});
</script>

<%- include('../partials/footer') %>
