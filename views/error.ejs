<%- include('partials/header', { title: 'Ошибка — Запись к врачу' }) %>

<div class="text-center py-5">
  <div class="mb-4" style="font-size:4rem;opacity:.3">
    <i class="bi bi-exclamation-triangle text-danger"></i>
  </div>
  <h3 class="fw-bold text-muted"><%= typeof message !== 'undefined' ? message : 'Что-то пошло не так' %></h3>
  <p class="text-muted mb-4">Попробуйте вернуться на предыдущую страницу или на главную.</p>
  <a href="/" class="btn btn-primary px-4">
    <i class="bi bi-house me-2"></i>На главную
  </a>
</div>

<%- include('partials/footer') %>
