<%
const MONTHS = ['января','февраля','марта','апреля','мая','июня',
                'июля','августа','сентября','октября','ноября','декабря'];
function fmtDate(str) {
  if(!str)return '—';
  const p=String(str).split('-');
  return parseInt(p[2],10)+' '+MONTHS[parseInt(p[1],10)-1]+' '+p[0];
}
function fmtPeriod(r){
  if(!r.date_from) return '—';
  if(r.date_from === r.date_to) return fmtDate(r.date_from);
  return fmtDate(r.date_from) + ' – ' + fmtDate(r.date_to);
}
function fmtTime(r){
  if(r.is_day_off) return 'Выходной';
  return (r.start_time || '—') + '–' + (r.end_time || '—');
}
function fmtType(r){
  return r.is_day_off ? 'Нерабочий период' : 'Изменённый режим';
}
%>
<%- include('../partials/header', { title: title }) %>
<% var dsTitle = 'Нерабочие дни и график'; var dsSubtitle = 'Периоды выходных и особый режим работы'; var dsIcon = 'bi-calendar-x'; %>
<%- include('../partials/ds-page-header') %>
<div class="d-flex flex-wrap justify-content-end mb-3">
  <button type="button" class="btn btn-primary btn-sm rounded-pill" data-bs-toggle="modal" data-bs-target="#addExcModal">
    <i class="bi bi-plus-circle me-1"></i>Добавить
  </button>
</div>

<% if (success) { %>
  <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle-fill me-2"></i><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>
<% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>

<% if (upcoming.length) { %>
  <h5 class="fw-semibold mb-3">Предстоящие изменения</h5>
  <div class="app-table-wrap app-table-wrap--sticky mb-4">
    <div class="table-responsive app-table-responsive">
      <table class="table app-table table-hover mb-0">
        <thead>
          <tr>
            <th>Период</th>
            <th>Тип</th>
            <th>Причина</th>
            <th>Время</th>
            <th class="text-end">Действия</th>
          </tr>
        </thead>
        <tbody>
          <% upcoming.forEach(function(e) { %>
            <tr>
              <td class="fw-semibold"><%= fmtPeriod(e) %></td>
              <td><span class="badge bg-light text-dark"><%= fmtType(e) %></span></td>
              <td><%= e.reason || '—' %></td>
              <td><%= fmtTime(e) %></td>
              <td class="text-end">
                <form method="POST" action="/doctor/time-off/<%= e.id %>/delete" class="d-inline"
                  onsubmit="return confirm('Удалить изменение графика?')">
                  <%- include('../partials/csrf') %>
                  <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<% if (past.length) { %>
  <h5 class="fw-semibold mb-3 text-muted">Прошедшие изменения</h5>
  <div class="app-table-wrap app-table-wrap--sticky mb-4 opacity-65">
    <div class="table-responsive app-table-responsive">
      <table class="table app-table table-hover mb-0">
        <thead><tr><th>Период</th><th>Тип</th><th>Причина</th><th>Время</th></tr></thead>
        <tbody>
          <% past.forEach(function(e) { %>
            <tr>
              <td><%= fmtPeriod(e) %></td>
              <td><%= fmtType(e) %></td>
              <td><%= e.reason || '—' %></td>
              <td><%= fmtTime(e) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<% if (!upcoming.length && !past.length) { %>
  <div class="empty-state text-center app-card p-5">
    <div class="empty-state__icon text-muted"><i class="bi bi-calendar-check"></i></div>
    <p class="text-muted mt-2 mb-0">Изменений графика нет</p>
  </div>
<% } %>

<!-- Модальное окно добавления -->
<div class="modal fade" id="addExcModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <form method="POST" action="/doctor/time-off" id="excForm">
        <%- include('../partials/csrf') %>
        <div class="modal-header"><h5 class="modal-title fw-bold">Изменение графика</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="mb-3">
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="radio" name="mode" id="modeSingle" value="single" <%= form.mode !== 'period' ? 'checked' : '' %>>
              <label class="form-check-label" for="modeSingle">Один день</label>
            </div>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="radio" name="mode" id="modePeriod" value="period" <%= form.mode === 'period' ? 'checked' : '' %>>
              <label class="form-check-label" for="modePeriod">Период (несколько дней)</label>
            </div>
          </div>

          <p class="form-label fw-semibold mb-2" id="dateFromLabel">Дата</p>
          <p class="small text-muted mb-2" id="vacCalHint">Навигация по месяцам не сбрасывает выбор. В режиме периода: первый клик — начало, второй — конец (можно в другом месяце).</p>
          <input type="hidden" name="exception_date" id="excDateFrom" value="<%= form.exception_date %>" required>
          <input type="hidden" name="date_to" id="excDateTo" value="<%= form.date_to %>">
          <div
            class="booking-cal card border-0 shadow-sm mb-3"
            data-vacation-calendar="1"
            data-min="<%= todayStr %>"
            data-input-from="excDateFrom"
            data-input-to="excDateTo"
          >
            <div class="card-body p-3">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <button type="button" class="btn btn-outline-primary btn-sm rounded-circle booking-cal-nav" data-vac-prev aria-label="Предыдущий месяц">
                  <i class="bi bi-chevron-left"></i>
                </button>
                <span class="fw-bold text-center px-2" data-vac-title></span>
                <button type="button" class="btn btn-outline-primary btn-sm rounded-circle booking-cal-nav" data-vac-next aria-label="Следующий месяц">
                  <i class="bi bi-chevron-right"></i>
                </button>
              </div>
              <div class="booking-cal-weekdays">
                <span>Пн</span><span>Вт</span><span>Ср</span><span>Чт</span><span>Пт</span><span>Сб</span><span>Вс</span>
              </div>
              <div class="booking-cal-grid" data-vac-grid></div>
              <p class="small fw-semibold text-primary mt-3 mb-0" data-vac-summary>Выберите дату в календаре</p>
            </div>
          </div>

          <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" role="switch" id="isDayOff" name="is_day_off" <%= form.is_day_off ? 'checked' : '' %>>
            <label class="form-check-label fw-semibold" for="isDayOff">Полный выходной</label>
          </div>

          <div class="row g-3 mb-3 <%= form.is_day_off ? 'd-none' : '' %>" id="timeRow">
            <div class="col">
              <label class="form-label fw-semibold">Начало приёма</label>
              <input type="time" class="form-control" name="start_time" id="startTime" value="<%= form.start_time %>">
            </div>
            <div class="col">
              <label class="form-label fw-semibold">Окончание приёма</label>
              <input type="time" class="form-control" name="end_time" id="endTime" value="<%= form.end_time %>">
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Причина</label>
            <textarea class="form-control" name="reason" rows="2" placeholder="Отпуск, больничный и т.д."><%= form.reason %></textarea>
          </div>

          <div class="alert alert-warning small py-2 mb-0">
            <i class="bi bi-exclamation-triangle me-1"></i>
            Записи, которые попадают в нерабочий период (или вне указанного времени), будут отменены автоматически, пациенты получат уведомления.
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Добавить</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
(function() {
  const modeSingle = document.getElementById('modeSingle');
  const modePeriod = document.getElementById('modePeriod');
  const dateFromLabel = document.getElementById('dateFromLabel');
  const vacCalHint = document.getElementById('vacCalHint');
  const excDateTo = document.getElementById('excDateTo');
  const isDayOff = document.getElementById('isDayOff');
  const timeRow = document.getElementById('timeRow');
  const startTime = document.getElementById('startTime');
  const endTime = document.getElementById('endTime');

  function toggle() {
    const isPeriod = modePeriod.checked;
    dateFromLabel.textContent = isPeriod ? 'Даты периода' : 'Дата';
    if (vacCalHint) {
      vacCalHint.style.display = isPeriod ? '' : 'none';
    }
    excDateTo.required = isPeriod;
  }
  function toggleTime() {
    const off = isDayOff.checked;
    timeRow.classList.toggle('d-none', off);
    startTime.required = !off;
    endTime.required = !off;
  }

  modeSingle.addEventListener('change', toggle);
  modePeriod.addEventListener('change', toggle);
  isDayOff.addEventListener('change', toggleTime);
  toggle();
  toggleTime();
})();
</script>

<%- include('../partials/footer') %>
