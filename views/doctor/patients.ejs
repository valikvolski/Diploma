<%
const MONTHS = ['января','февраля','марта','апреля','мая','июня','июля','августа','сентября','октября','ноября','декабря'];
function fmtDate(s){if(!s)return '—';const p=String(s).split('-');return parseInt(p[2],10)+' '+MONTHS[parseInt(p[1],10)-1]+' '+p[0];}
function statusBadge(s){
  switch(s){
    case 'booked':return '<span class="status-pill status-pill--booked">Забронировано</span>';
    case 'completed':return '<span class="status-pill status-pill--completed">Принят</span>';
    case 'cancelled':return '<span class="status-pill status-pill--cancelled">Отменён</span>';
    default:return '<span class="status-pill status-pill--cancelled">'+s+'</span>';
  }
}
%>
<%- include('../partials/header', { title: title }) %>
<% var dsTitle = 'Пациенты на приём'; var dsSubtitle = 'Записи на выбранную дату и смена статуса приёма'; var dsIcon = 'bi-people'; %>
<%- include('../partials/ds-page-header') %>
<div class="d-flex flex-wrap justify-content-end mb-3">
  <form method="GET" action="/doctor/patients" class="d-flex flex-column align-items-end gap-1">
    <label class="form-label small fw-semibold text-muted mb-0">Дата</label>
    <input type="date" name="date" class="form-control form-control-sm" style="width: auto; min-width: 10rem;" value="<%= selectedDate %>" data-unified-calendar="1" data-auto-submit="1">
  </form>
</div>

<% if (success) { %>
  <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle-fill me-2"></i><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>
<% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>

<p class="text-muted mb-3"><%= fmtDate(selectedDate) %> &mdash; записей: <strong><%= appointments.length %></strong></p>

<% if (appointments.length === 0) { %>
  <div class="empty-state text-center app-card p-5">
    <div class="empty-state__icon text-muted"><i class="bi bi-calendar-x"></i></div>
    <p class="text-muted mt-2 mb-0">Нет записей на эту дату</p>
  </div>
<% } else { %>
  <div class="app-table-wrap app-table-wrap--sticky">
    <div class="table-responsive app-table-responsive">
      <table class="table app-table table-hover mb-0">
        <thead>
          <tr><th>Время</th><th>Пациент</th><th>Телефон</th><th>Статус</th><th class="text-end">Действия</th></tr>
        </thead>
        <tbody>
          <% appointments.forEach(function(a) { %>
            <tr>
              <td class="fw-bold"><%= a.appointment_time %></td>
              <td><%= a.last_name %> <%= a.first_name %> <%= a.middle_name %></td>
              <td><%= a.phone || '—' %></td>
              <td><%- statusBadge(a.status) %></td>
              <td class="text-end">
                <% if (a.status === 'booked') { %>
                  <form method="POST" action="/doctor/appointments/<%= a.appointment_id %>/status" class="d-inline">
                    <%- include('../partials/csrf') %>
                    <input type="hidden" name="status" value="completed">
                    <input type="hidden" name="redirect_date" value="<%= selectedDate %>">
                    <button class="btn btn-sm btn-outline-success" title="Принят"><i class="bi bi-check-lg"></i></button>
                  </form>
                  <form method="POST" action="/doctor/appointments/<%= a.appointment_id %>/status" class="d-inline"
                    onsubmit="return confirm('Отменить запись?')">
                    <%- include('../partials/csrf') %>
                    <input type="hidden" name="status" value="cancelled">
                    <input type="hidden" name="redirect_date" value="<%= selectedDate %>">
                    <button class="btn btn-sm btn-outline-danger" title="Отменить"><i class="bi bi-x-lg"></i></button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<%- include('../partials/footer') %>
