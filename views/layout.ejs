<!DOCTYPE html>
<html lang="ru" data-bs-theme="light" data-app-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'МедЗапись' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="app-body">
  <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom">
    <div class="container">
      <a class="navbar-brand fw-semibold" href="/">МедЗапись</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#layoutNav" aria-controls="layoutNav" aria-expanded="false" aria-label="Меню">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="layoutNav">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/">Главная</a></li>
          <li class="nav-item"><a class="nav-link" href="/doctors">Врачи</a></li>
          <% if (typeof user !== 'undefined' && user) { %>
            <li class="nav-item">
              <form method="POST" action="/auth/logout" class="d-inline">
                <button type="submit" class="nav-link btn btn-link p-0 border-0 align-baseline">Выйти</button>
              </form>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="/auth/login">Вход</a></li>
            <li class="nav-item"><a class="nav-link" href="/auth/register">Регистрация</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <%- typeof body !== 'undefined' ? body : '' %>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
