<%
const MONTHS = ['января','февраля','марта','апреля','мая','июня','июля','августа','сентября','октября','ноября','декабря'];
function fmtDate(s){if(!s)return '—';const p=String(s).split('-');return parseInt(p[2],10)+' '+MONTHS[parseInt(p[1],10)-1]+' '+p[0];}
function statusBadge(s){
  switch(s){
    case 'booked':return '<span class="badge bg-success">Забронировано</span>';
    case 'completed':return '<span class="badge bg-primary">Завершено</span>';
    case 'cancelled':return '<span class="badge bg-secondary">Отменено</span>';
    default:return '<span class="badge bg-secondary">'+s+'</span>';
  }
}
%>
<%- include('../partials/header', { title: title }) %>

<h3 class="fw-bold mb-4"><i class="bi bi-journal-text text-primary me-2"></i>Все записи</h3>

<!-- Фильтры -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body p-3">
    <form method="GET" action="/admin/appointments" class="row g-3 align-items-end">
      <div class="col-md-2">
        <label class="form-label small fw-semibold">Дата от</label>
        <input type="date" class="form-control form-control-sm" name="date_from" value="<%= filters.date_from %>">
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-semibold">Дата до</label>
        <input type="date" class="form-control form-control-sm" name="date_to" value="<%= filters.date_to %>">
      </div>
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Врач</label>
        <select class="form-select form-select-sm" name="doctor_id">
          <option value="">— Все врачи —</option>
          <% doctors.forEach(function(d){ %>
            <option value="<%= d.id %>" <%= filters.doctor_id==d.id?'selected':'' %>><%= d.last_name %> <%= d.first_name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-semibold">Статус</label>
        <select class="form-select form-select-sm" name="status">
          <option value="">Все</option>
          <option value="booked" <%= filters.status==='booked'?'selected':'' %>>Забронировано</option>
          <option value="completed" <%= filters.status==='completed'?'selected':'' %>>Завершено</option>
          <option value="cancelled" <%= filters.status==='cancelled'?'selected':'' %>>Отменено</option>
        </select>
      </div>
      <div class="col-md-3 d-flex gap-2">
        <button class="btn btn-primary btn-sm flex-fill"><i class="bi bi-search me-1"></i>Найти</button>
        <% if (filters.date_from||filters.date_to||filters.status||filters.doctor_id) { %>
          <a href="/admin/appointments" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-lg"></i></a>
        <% } %>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr><th>#</th><th>Дата</th><th>Время</th><th>Пациент</th><th>Врач</th><th>Специализация</th><th>Статус</th></tr>
      </thead>
      <tbody>
        <% if(appointments.length===0){ %>
          <tr><td colspan="7" class="text-center text-muted py-4">Записей не найдено</td></tr>
        <% } %>
        <% appointments.forEach(function(a){ %>
          <tr>
            <td><%= a.id %></td>
            <td><%= fmtDate(a.appointment_date) %></td>
            <td class="fw-semibold"><%= a.appointment_time %></td>
            <td><%= a.p_last %> <%= a.p_first %></td>
            <td><%= a.d_last %> <%= a.d_first %></td>
            <td><% if(a.specialization){%><span class="badge spec-badge"><%= a.specialization %></span><%}else{%>—<%}%></td>
            <td><%- statusBadge(a.status) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<p class="text-muted small mt-3">Показано: <strong><%= appointments.length %></strong></p>

<%- include('../partials/footer') %>
