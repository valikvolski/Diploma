<%
const MONTHS = ['января','февраля','марта','апреля','мая','июня','июля','августа','сентября','октября','ноября','декабря'];
function fmtDate(s){if(!s)return '—';const p=String(s).split('-');return parseInt(p[2],10)+' '+MONTHS[parseInt(p[1],10)-1]+' '+p[0];}
function statusBadge(s){
  switch(s){
    case 'booked':return '<span class="status-pill status-pill--booked">Забронировано</span>';
    case 'completed':return '<span class="status-pill status-pill--completed">Завершено</span>';
    case 'cancelled':return '<span class="status-pill status-pill--cancelled">Отменено</span>';
    default:return '<span class="status-pill status-pill--cancelled">'+s+'</span>';
  }
}
%>
<%- include('../partials/header', { title: title }) %>
<% var dsTitle = 'Все записи'; var dsSubtitle = 'Фильтрация по дате, врачу и статусу'; var dsIcon = 'bi-journal-text'; %>
<%- include('../partials/ds-page-header') %>

<div class="filter-panel app-card border-0 shadow-sm mb-4">
  <div class="card-body p-4">
    <form method="GET" action="/admin/appointments" class="row g-3 align-items-end admin-filter-form">
      <div class="col-md-6 col-lg-2">
        <label class="form-label small fw-semibold">Дата от</label>
        <input type="date" class="form-control form-control-sm" name="date_from" value="<%= filters.date_from %>" data-unified-calendar="1">
      </div>
      <div class="col-md-6 col-lg-2">
        <label class="form-label small fw-semibold">Дата до</label>
        <input type="date" class="form-control form-control-sm" name="date_to" value="<%= filters.date_to %>" data-unified-calendar="1">
      </div>
      <div class="col-md-6 col-lg-3">
        <label class="form-label small fw-semibold">Врач</label>
        <select class="form-select form-select-sm" name="doctor_id">
          <option value="">— Все врачи —</option>
          <% doctors.forEach(function(d){ %>
            <option value="<%= d.id %>" <%= filters.doctor_id==d.id?'selected':'' %>><%= d.last_name %> <%= d.first_name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-6 col-lg-2">
        <label class="form-label small fw-semibold">Статус</label>
        <select class="form-select form-select-sm" name="status">
          <option value="">Все</option>
          <option value="booked" <%= filters.status==='booked'?'selected':'' %>>Забронировано</option>
          <option value="completed" <%= filters.status==='completed'?'selected':'' %>>Завершено</option>
          <option value="cancelled" <%= filters.status==='cancelled'?'selected':'' %>>Отменено</option>
        </select>
      </div>
      <div class="col-md-6 col-lg-3">
        <label class="form-label small fw-semibold">Пациент</label>
        <input type="text" class="form-control form-control-sm" name="patient_search" value="<%= filters.patient_search || '' %>" placeholder="ФИО или email">
      </div>
      <div class="col-12 d-flex gap-2 admin-filter-actions justify-content-end flex-wrap">
        <input type="hidden" name="limit" value="<%= pagination && pagination.limit ? pagination.limit : 10 %>">
        <button type="submit" class="btn btn-primary btn-sm px-3 text-nowrap"><i class="bi bi-search me-1"></i>Найти</button>
        <a href="/admin/appointments" class="btn btn-outline-secondary btn-sm">Сброс</a>
      </div>
    </form>
  </div>
</div>

<p class="text-muted small mb-3">Всего записей: <strong><%= totalCount || 0 %></strong></p>

<div class="app-table-wrap app-table-wrap--sticky">
  <div class="table-responsive app-table-responsive">
    <table class="table app-table table-hover align-middle mb-0">
      <thead>
        <tr><th class="nowrap-heading">#</th><th>Дата</th><th class="nowrap-heading">Время</th><th>Пациент</th><th>Врач</th><th>Специализация</th><th>Статус</th></tr>
      </thead>
      <tbody>
        <% if(appointments.length===0){ %>
          <tr>
            <td colspan="7" class="p-0 border-0">
              <div class="text-center py-5 app-card app-card--static m-3">
                <div class="empty-state__icon text-muted"><i class="bi bi-inbox"></i></div>
                <p class="text-muted mb-0 mt-2">Записей не найдено</p>
              </div>
            </td>
          </tr>
        <% } %>
        <% appointments.forEach(function(a){ %>
          <tr>
            <td><%= a.id %></td>
            <td><%= fmtDate(a.appointment_date) %></td>
            <% var _tRaw = a.appointment_time != null ? String(a.appointment_time).trim() : ''; %>
            <% var _tDisp = _tRaw ? _tRaw.substring(0, 5) : '—'; %>
            <td class="fw-semibold text-nowrap"><%= _tDisp %></td>
            <td><%= a.p_last %> <%= a.p_first %></td>
            <td><%= a.d_last %> <%= a.d_first %></td>
            <td><% if(a.specialization){%><span class="badge spec-badge"><%= a.specialization %></span><%}else{%>—<%}%></td>
            <td><%- statusBadge(a.status) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%
  var p = pagination || { currentPage: 1, totalPages: 1, hasPrev: false, hasNext: false, limit: 10 };
  function apptsPageUrl(pg) {
    const qp = new URLSearchParams();
    if (filters.date_from) qp.set('date_from', filters.date_from);
    if (filters.date_to) qp.set('date_to', filters.date_to);
    if (filters.status) qp.set('status', filters.status);
    if (filters.doctor_id) qp.set('doctor_id', filters.doctor_id);
    if (filters.patient_search) qp.set('patient_search', filters.patient_search);
    qp.set('limit', String(p.limit || 10));
    qp.set('page', String(pg));
    return '/admin/appointments?' + qp.toString();
  }
%>
<%- include('../partials/admin-pagination', {
  p: p,
  pageUrl: apptsPageUrl,
  ariaLabel: 'Пагинация записей'
}) %>

<%- include('../partials/footer') %>
