<%- include('../partials/header', { title: title }) %>
<% var dsTitle = 'Пользователи'; var dsSubtitle = 'Блокировка, роли и удаление учётных записей'; var dsIcon = 'bi-people'; %>
<%- include('../partials/ds-page-header') %>
<div class="d-flex flex-wrap justify-content-end mb-3">
  <form method="GET" action="/admin/users" class="d-flex gap-2">
    <select name="role" class="form-select form-select-sm" style="min-width: 11rem;" onchange="this.form.submit()">
      <option value="">Все роли</option>
      <option value="patient" <%= roleFilter==='patient'?'selected':'' %>>Пациенты</option>
      <option value="doctor" <%= roleFilter==='doctor'?'selected':'' %>>Врачи</option>
      <option value="admin" <%= roleFilter==='admin'?'selected':'' %>>Администраторы</option>
    </select>
  </form>
</div>

<% if (success) { %><div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
<% if (error) { %><div class="alert alert-danger alert-dismissible fade show"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>

<div class="app-table-wrap app-table-wrap--sticky">
  <div class="table-responsive app-table-responsive">
    <table class="table app-table table-hover mb-0">
      <thead>
        <tr><th>#</th><th>Email</th><th>ФИО</th><th>Роль</th><th>Статус</th><th class="text-end">Действия</th></tr>
      </thead>
      <tbody>
        <% users.forEach(function(u) { %>
          <tr class="<%= u.is_blocked ? 'table-secondary' : '' %>">
            <td><%= u.id %></td>
            <td><%= u.email %></td>
            <td class="fw-semibold"><%= u.last_name %> <%= u.first_name %></td>
            <td>
              <% if(u.role==='admin'){%><span class="badge bg-dark">Админ</span><%}
                 else if(u.role==='doctor'){%><span class="badge bg-primary">Врач</span><%}
                 else{%><span class="badge bg-info text-dark">Пациент</span><%}%>
            </td>
            <td>
              <% if(u.is_blocked){%><span class="status-pill status-pill--blocked"><i class="bi bi-lock-fill"></i>Заблокирован</span><%}else{%><span class="status-pill status-pill--active"><i class="bi bi-check-circle"></i>Активен</span><%}%>
            </td>
            <td class="text-end text-nowrap">
              <% if (u.role === 'patient') { %>
                <a href="/admin/users/<%= u.id %>/change-role" class="btn btn-sm btn-outline-primary" title="Сделать врачом">
                  <i class="bi bi-person-badge"></i>
                </a>
              <% } %>
              <form method="POST" action="/admin/users/<%= u.id %>/block" class="d-inline">
                <%- include('../partials/csrf') %>
                <% if(u.is_blocked){ %>
                  <button class="btn btn-sm btn-outline-success" title="Разблокировать"><i class="bi bi-unlock"></i></button>
                <% } else { %>
                  <button class="btn btn-sm btn-outline-warning" title="Заблокировать"
                    onclick="return confirm('Заблокировать <%= u.last_name %> <%= u.first_name %>?')"><i class="bi bi-lock"></i></button>
                <% } %>
              </form>
              <form method="POST" action="/admin/users/<%= u.id %>/delete" class="d-inline"
                onsubmit="return confirm('Удалить пользователя <%= u.last_name %> <%= u.first_name %>? Это действие необратимо!')">
                <%- include('../partials/csrf') %>
                <button class="btn btn-sm btn-outline-danger" title="Удалить"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<p class="text-muted small mt-3">Всего: <strong><%= users.length %></strong></p>

<%- include('../partials/footer') %>
