<%- include('../partials/header', { title: title }) %>
<% var dsTitle = 'Пользователи'; var dsSubtitle = 'Блокировка, роли и удаление учётных записей'; var dsIcon = 'bi-people'; %>
<%- include('../partials/ds-page-header') %>

<% if (success) { %><div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
<% if (error) { %><div class="alert alert-danger alert-dismissible fade show"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>

<div class="card border-0 shadow-sm mb-4 rounded-4">
  <div class="card-body p-4">
    <form method="GET" action="/admin/users" class="row g-3 align-items-end admin-filter-form">
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Роль</label>
        <select name="role" class="form-select form-select-sm">
          <option value="">Все роли</option>
          <option value="patient" <%= filters && filters.role==='patient'?'selected':'' %>>Пациенты</option>
          <option value="doctor" <%= filters && filters.role==='doctor'?'selected':'' %>>Врачи</option>
          <option value="admin" <%= filters && filters.role==='admin'?'selected':'' %>>Администраторы</option>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Статус</label>
        <select name="blocked" class="form-select form-select-sm">
          <option value="">Все</option>
          <option value="active" <%= filters && filters.blocked==='active'?'selected':'' %>>Активен</option>
          <option value="blocked" <%= filters && filters.blocked==='blocked'?'selected':'' %>>Заблокирован</option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label small fw-semibold">Поиск</label>
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Email или ФИО" value="<%= filters && filters.search ? filters.search : '' %>">
      </div>
      <div class="col-md-2 d-flex admin-filter-actions flex-wrap justify-content-start justify-content-md-end">
        <input type="hidden" name="limit" value="<%= pagination && pagination.limit ? pagination.limit : 10 %>">
        <button type="submit" class="btn btn-primary btn-sm px-3"><i class="bi bi-search" aria-hidden="true"></i><span class="visually-hidden">Найти</span></button>
        <a href="/admin/users" class="btn btn-outline-secondary btn-sm">Сброс</a>
      </div>
    </form>
  </div>
</div>

<p class="text-muted small mb-3">Всего записей: <strong><%= totalCount || 0 %></strong></p>

<div class="app-table-wrap app-table-wrap--sticky">
  <div class="table-responsive app-table-responsive">
    <table class="table app-table table-hover align-middle mb-0">
      <thead>
        <tr><th class="nowrap-heading">#</th><th>Email</th><th>ФИО</th><th>Роль</th><th>Статус</th><th class="text-end nowrap-heading">Действия</th></tr>
      </thead>
      <tbody>
        <% if (!users || users.length === 0) { %>
          <tr>
            <td colspan="6" class="p-0 border-0">
              <div class="text-center py-5 app-card app-card--static m-3">
                <div class="empty-state__icon text-muted"><i class="bi bi-inbox"></i></div>
                <p class="text-muted mb-0 mt-2">Пользователи не найдены</p>
              </div>
            </td>
          </tr>
        <% } %>
        <% (users || []).forEach(function(u) { %>
          <tr class="<%= u.is_blocked ? 'table-secondary' : '' %>">
            <td><%= u.id %></td>
            <td><%= u.email %></td>
            <td class="fw-semibold"><%= u.last_name %> <%= u.first_name %></td>
            <td>
              <% if(u.role==='admin'){%><span class="badge bg-dark">Админ</span><%}
                 else if(u.role==='doctor'){%><span class="badge bg-primary">Врач</span><%}
                 else{%><span class="badge bg-info text-dark">Пациент</span><%}%>
            </td>
            <td>
              <% if(u.is_blocked){%><span class="status-pill status-pill--blocked"><i class="bi bi-lock-fill"></i>Заблокирован</span><%}else{%><span class="status-pill status-pill--active"><i class="bi bi-check-circle"></i>Активен</span><%}%>
            </td>
            <td class="text-end align-middle">
              <div class="app-table-actions">
              <a href="/admin/users/<%= u.id %>" class="btn btn-sm btn-outline-primary" title="Просмотреть профиль">
                <i class="bi bi-person-lines-fill"></i>
              </a>
              <form method="POST" action="/admin/users/<%= u.id %>/block" class="mb-0 js-confirm-form" data-confirm-title="<%= u.is_blocked ? 'Разблокировка пользователя' : 'Блокировка пользователя' %>" data-confirm-name="<%= u.last_name %> <%= u.first_name %>" data-confirm-action="<%= u.is_blocked ? 'Разблокировать' : 'Заблокировать' %>">
                <%- include('../partials/csrf') %>
                <% if(u.is_blocked){ %>
                  <button type="button" class="btn btn-sm btn-outline-success js-open-confirm" title="Разблокировать"><i class="bi bi-unlock"></i></button>
                <% } else { %>
                  <button type="button" class="btn btn-sm btn-outline-warning js-open-confirm" title="Заблокировать"><i class="bi bi-lock"></i></button>
                <% } %>
              </form>
              <form method="POST" action="/admin/users/<%= u.id %>/delete" class="mb-0 js-confirm-form"
                data-confirm-title="Удаление пользователя"
                data-confirm-name="<%= u.last_name %> <%= u.first_name %>"
                data-confirm-action="Удалить">
                <%- include('../partials/csrf') %>
                <button type="button" class="btn btn-sm btn-outline-danger js-open-confirm" title="Удалить"><i class="bi bi-trash"></i></button>
              </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%
  var p = pagination || { currentPage: 1, totalPages: 1, hasPrev: false, hasNext: false, limit: 10 };
  function usersPageUrl(pg) {
    const qp = new URLSearchParams();
    if (filters && filters.role) qp.set('role', filters.role);
    if (filters && filters.blocked) qp.set('blocked', filters.blocked);
    if (filters && filters.search) qp.set('search', filters.search);
    qp.set('limit', String(p.limit || 10));
    qp.set('page', String(pg));
    return '/admin/users?' + qp.toString();
  }
%>
<%- include('../partials/admin-pagination', {
  p: p,
  pageUrl: usersPageUrl,
  ariaLabel: 'Пагинация пользователей'
}) %>

<div class="modal fade" id="adminConfirmModal" tabindex="-1" aria-labelledby="adminConfirmModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="adminConfirmModalLabel">Подтверждение действия</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
      </div>
      <div class="modal-body">
        <p class="mb-0">Вы действительно хотите выполнить действие для <strong id="adminConfirmName">этого объекта</strong>?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отмена</button>
        <button type="button" class="btn btn-danger" id="adminConfirmSubmit">Подтвердить</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    function initAdminConfirmModal() {
      var modalEl = document.getElementById('adminConfirmModal');
      if (!modalEl || !window.bootstrap) return false;
      var modal = new bootstrap.Modal(modalEl);
      var submitBtn = document.getElementById('adminConfirmSubmit');
      var nameEl = document.getElementById('adminConfirmName');
      var titleEl = document.getElementById('adminConfirmModalLabel');
      var pendingForm = null;

      document.querySelectorAll('.js-open-confirm').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var form = btn.closest('.js-confirm-form');
          if (!form) return;
          pendingForm = form;
          if (nameEl) nameEl.textContent = form.getAttribute('data-confirm-name') || 'выбранного объекта';
          if (titleEl) titleEl.textContent = form.getAttribute('data-confirm-title') || 'Подтверждение действия';
          if (submitBtn) submitBtn.textContent = form.getAttribute('data-confirm-action') || 'Подтвердить';
          modal.show();
        });
      });

      if (submitBtn) {
        submitBtn.addEventListener('click', function () {
          if (!pendingForm) return;
          pendingForm.submit();
        });
      }
      return true;
    }

    if (!initAdminConfirmModal()) {
      window.addEventListener('load', initAdminConfirmModal, { once: true });
    }
  })();
</script>

<%- include('../partials/footer') %>
