<%- include('../partials/header', { title: title, loadChoicesCss: typeof loadChoicesCss !== 'undefined' && loadChoicesCss }) %>
<% var dsTitle = doctor ? 'Редактирование врача' : 'Добавить врача'; var dsSubtitle = doctor ? ('Пользователь #' + doctor.id + (typeof doctor.profile_id !== 'undefined' && doctor.profile_id != null ? ', профиль #' + doctor.profile_id : '')) : 'Создание учётной записи и профиля врача'; var dsIcon = 'bi-person-badge'; var dsBackHref = '/admin/doctors'; var dsBackLabel = 'К списку врачей'; %>
<%- include('../partials/ds-page-header') %>

<div class="app-card app-narrow-card app-card--static">
  <div class="p-4 p-md-5">

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <% if (doctor) { %>
    <div class="admin-doctor-avatar-panel border rounded-3 p-3 p-md-4 mb-4">
      <h2 class="h6 fw-bold mb-3">Фото врача</h2>
      <div class="d-flex flex-column flex-md-row align-items-start gap-3">
        <%- include('../partials/user-avatar', { person: doctor, size: 'profile' }) %>
        <div class="flex-grow-1 w-100" style="min-width: 0;">
          <p class="small text-muted mb-2">JPG, PNG или WebP, до 2 МБ. Для каталога и карточки врача.</p>
          <div class="d-flex flex-wrap gap-2 align-items-center">
            <form method="POST" action="/admin/doctors/<%= doctor.id %>/avatar" enctype="multipart/form-data" class="d-flex flex-wrap align-items-center gap-2">
              <%- include('../partials/csrf') %>
              <input type="file" name="avatar" class="form-control form-control-sm" style="max-width: 220px;" accept="image/jpeg,image/png,image/webp,.jpg,.jpeg,.png,.webp" required />
              <button type="submit" class="btn btn-primary btn-sm rounded-pill"><i class="bi bi-upload me-1"></i>Загрузить</button>
            </form>
            <% if (doctor.avatar_path) { %>
            <form method="POST" action="/admin/doctors/<%= doctor.id %>/avatar/remove" class="d-inline" onsubmit="return confirm('Удалить фото врача?');">
              <%- include('../partials/csrf') %>
              <button type="submit" class="btn btn-outline-secondary btn-sm rounded-pill"><i class="bi bi-trash me-1"></i>Удалить</button>
            </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>
    <% } %>

    <% const chosen = typeof doctorSpecIds !== 'undefined' && doctorSpecIds ? doctorSpecIds : []; %>
    <% const prim = typeof primarySpecId !== 'undefined' ? primarySpecId : null; %>
    <script type="application/json" id="admin-spec-choices-config"><%- JSON.stringify({
      meta: specializations.map(function (s) {
        return { id: s.id, name: s.name, g: s.compat_group || 'therapy' };
      }),
      initialIds: chosen,
      initialPrimary: prim != null ? String(prim) : ''
    }) %></script>

    <form method="POST" action="<%= doctor ? '/admin/doctors/' + doctor.id + '/edit' : '/admin/doctors' %>">
      <%- include('../partials/csrf') %>
    <% if (doctor) { %>
      <input type="hidden" name="user_id" value="<%= doctor.id %>">
    <% } %>

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
          <input type="email" class="form-control" name="email" value="<%= doctor ? doctor.email || '' : '' %>" required>
        </div>
        <% if (!doctor) { %>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Пароль <span class="text-danger">*</span></label>
            <input type="password" class="form-control" name="password" required minlength="6">
          </div>
        <% } else { %>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Новый пароль</label>
            <input type="password" class="form-control" name="new_password" autocomplete="new-password" placeholder="Оставьте пустым, чтобы не менять" title="Если задаёте пароль — не менее 6 символов (проверка на сервере)">
            <div class="form-text">Если поле пустое, пароль не изменится.</div>
          </div>
        <% } %>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label fw-semibold">Фамилия <span class="text-danger">*</span></label>
          <input type="text" class="form-control" name="last_name" value="<%= doctor ? doctor.last_name : '' %>" required>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Имя <span class="text-danger">*</span></label>
          <input type="text" class="form-control" name="first_name" value="<%= doctor ? doctor.first_name : '' %>" required>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Отчество</label>
          <input type="text" class="form-control" name="middle_name" value="<%= doctor ? doctor.middle_name || '' : '' %>">
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Телефон</label>
          <input type="tel" class="form-control" name="phone" value="<%= doctor ? doctor.phone || '' : '' %>">
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-12 admin-spec-field">
          <label class="form-label fw-semibold" for="admin-spec-multi">Специализации <span class="text-danger">*</span></label>
          <div id="spec-field-error" class="invalid-feedback admin-spec-error d-none" role="alert"></div>
          <select
            id="admin-spec-multi"
            class="form-select choices-spec-multi"
            name="specialization_ids[]"
            multiple
            required
            aria-describedby="spec-field-error specCompatCompact"
          >
            <% specializations.forEach(function (s) { %>
              <option value="<%= s.id %>" <%= chosen.indexOf(s.id) !== -1 ? 'selected' : '' %>><%= s.name %></option>
            <% }) %>
          </select>

          <label class="form-label fw-semibold mt-3 mb-2" for="admin-spec-primary">Основная специализация</label>
          <select id="admin-spec-primary" class="form-select choices-spec-primary" name="primary_specialization_id" aria-label="Основная специализация">
            <option value="">— Не выбрано —</option>
            <% specializations.forEach(function (s) { %>
              <% if (chosen.indexOf(s.id) !== -1) { %>
                <option value="<%= s.id %>" <%= prim == s.id ? 'selected' : '' %>><%= s.name %></option>
              <% } %>
            <% }) %>
          </select>
          <p class="small mb-0 mt-2 d-none admin-spec-hint text-muted" id="specCompatCompact"></p>
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label fw-semibold">Кабинет</label>
          <input type="text" class="form-control" name="cabinet" value="<%= doctor ? doctor.cabinet || '' : '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Стаж (лет)</label>
          <input type="number" class="form-control" name="experience_years" min="0" value="<%= doctor ? doctor.experience_years || 0 : 0 %>">
        </div>
        <% if (doctor) { %>
          <div class="col-md-4">
            <label class="form-label fw-semibold">Статус</label>
            <select class="form-select" name="is_blocked">
              <option value="false" <%= !doctor.is_blocked ? 'selected' : '' %>>Активен</option>
              <option value="true" <%= doctor.is_blocked ? 'selected' : '' %>>Заблокирован</option>
            </select>
          </div>
        <% } %>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Образование</label>
        <textarea class="form-control" name="education" rows="2"><%= doctor ? doctor.education || '' : '' %></textarea>
      </div>

      <div class="mb-4">
        <label class="form-label fw-semibold">Описание</label>
        <textarea class="form-control" name="description" rows="3"><%= doctor ? doctor.description || '' : '' %></textarea>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg me-1"></i><%= doctor ? 'Сохранить изменения' : 'Добавить врача' %></button>
        <a href="/admin/doctors" class="btn btn-outline-secondary">Отмена</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
