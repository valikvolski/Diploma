<%- include('../partials/header', { title: title }) %>
<% var dsTitle = 'Специализации'; var dsSubtitle = 'Справочник для каталога врачей и форм'; var dsIcon = 'bi-tags'; %>
<%- include('../partials/ds-page-header') %>

<% if (success) { %><div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
<% if (error) { %><div class="alert alert-danger alert-dismissible fade show"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>

<div class="row g-4">
  <div class="col-md-8">
    <div class="app-table-wrap app-table-wrap--sticky">
      <div class="table-responsive app-table-responsive">
        <table class="table app-table table-hover mb-0">
          <thead><tr><th>#</th><th>Название</th><th>Группа совместимости</th><th>Врачей</th><th class="text-end">Действие</th></tr></thead>
          <tbody>
            <% specializations.forEach(function(s) { %>
              <tr>
                <td><%= s.id %></td>
                <td class="fw-semibold"><%= s.name %></td>
                <td><code class="small"><%= s.compat_group || 'therapy' %></code></td>
                <td><span class="badge app-count-badge"><%= s.doctor_count %></span></td>
                <td class="text-end">
                  <form method="POST" action="/admin/specializations/<%= s.id %>/delete" class="d-inline"
                    onsubmit="return confirm('Удалить «<%= s.name %>»?')">
                    <%- include('../partials/csrf') %>
                    <button class="btn btn-sm btn-outline-danger" <%= parseInt(s.doctor_count) > 0 ? 'disabled' : '' %>><i class="bi bi-trash"></i></button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="app-card app-card--static p-4 h-100">
      <h2 class="h6 text-uppercase text-muted fw-semibold letter-spacing-wide mb-3"><i class="bi bi-plus-circle text-primary me-2"></i>Новая запись</h2>
      <form method="POST" action="/admin/specializations">
        <%- include('../partials/csrf') %>
        <div class="mb-3">
          <label class="form-label fw-semibold small">Название</label>
          <input type="text" class="form-control" name="name" placeholder="Например, Терапевт" required>
        </div>
        <button type="submit" class="btn btn-primary w-100 rounded-pill"><i class="bi bi-plus-circle me-1"></i>Добавить</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
