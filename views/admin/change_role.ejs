<%- include('../partials/header', { title: title, loadChoicesCss: typeof loadChoicesCss !== 'undefined' && loadChoicesCss }) %>
<% var dsTitle = 'Назначить врачом'; var dsSubtitle = targetUser.last_name + ' ' + targetUser.first_name + ' · ' + targetUser.email; var dsIcon = 'bi-person-badge'; var dsBackHref = '/admin/users'; var dsBackLabel = 'К пользователям'; %>
<%- include('../partials/ds-page-header') %>

<div class="app-card app-narrow-card--md app-card--static">
  <div class="p-4 p-md-5">

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <script type="application/json" id="admin-spec-choices-config"><%- JSON.stringify({
      meta: specializations.map(function (s) {
        return { id: s.id, name: s.name, g: s.compat_group || 'therapy' };
      }),
      initialIds: [],
      initialPrimary: ''
    }) %></script>

    <form method="POST" action="/admin/users/<%= targetUser.id %>/change-role">
      <div class="mb-3">
        <label class="form-label fw-semibold" for="admin-spec-multi">Специализации <span class="text-danger">*</span></label>
        <p class="small text-muted mb-2">Только совместимые специализации из одной группы (см. подсказку при выборе).</p>
        <select
          id="admin-spec-multi"
          class="form-select choices-spec-multi"
          name="specialization_ids[]"
          multiple
          required
          aria-describedby="specCompatHint"
        >
          <% specializations.forEach(function (s) { %>
            <option value="<%= s.id %>"><%= s.name %></option>
          <% }) %>
        </select>

        <label class="form-label fw-semibold mt-3" for="admin-spec-primary">Основная специализация</label>
        <p class="small text-muted mb-2">Будет показана первой в талонах и в списках.</p>
        <select id="admin-spec-primary" class="form-select choices-spec-primary" name="primary_specialization_id">
          <option value="">— Не выбрано —</option>
        </select>

        <p class="small mt-2 mb-0" id="specCompatHint"><span class="text-muted">Подсказка:</span> <span id="specCompatHintText"></span></p>
      </div>
      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Кабинет</label>
          <input type="text" class="form-control" name="cabinet" placeholder="101">
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Стаж (лет)</label>
          <input type="number" class="form-control" name="experience_years" min="0" value="0">
        </div>
      </div>
      <div class="mb-3">
        <label class="form-label fw-semibold">Образование</label>
        <textarea class="form-control" name="education" rows="2"></textarea>
      </div>
      <div class="mb-4">
        <label class="form-label fw-semibold">Описание</label>
        <textarea class="form-control" name="description" rows="3"></textarea>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-person-badge me-1"></i>Назначить врачом</button>
        <a href="/admin/users" class="btn btn-outline-secondary">Отмена</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
