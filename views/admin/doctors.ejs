<%- include('../partials/header', { title: title }) %>
<% var dsTitle = 'Управление врачами'; var dsSubtitle = 'Создание, редактирование и блокировка учётных записей'; var dsIcon = 'bi-person-badge'; var dsActions = '<a href="/admin/doctors/new" class="btn btn-primary btn-sm rounded-pill"><i class="bi bi-plus-circle me-1"></i>Добавить врача</a>'; %>
<%- include('../partials/ds-page-header') %>

<% if (success) { %><div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
<% if (error) { %><div class="alert alert-danger alert-dismissible fade show"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>

<div class="app-table-wrap app-table-wrap--sticky">
  <div class="table-responsive app-table-responsive">
    <table class="table app-table table-hover mb-0">
      <thead>
        <tr><th class="text-center" style="width:52px"></th><th>#</th><th>ФИО</th><th>Специализация</th><th>Кабинет</th><th>Стаж</th><th>Статус</th><th class="text-end">Действия</th></tr>
      </thead>
      <tbody>
        <% doctors.forEach(function(d) { %>
          <tr class="<%= d.is_blocked ? 'table-secondary' : '' %>">
            <td class="text-center align-middle py-2">
              <%- include('../partials/user-avatar', { person: d, size: 'md' }) %>
            </td>
            <td><%= d.id %></td>
            <td class="fw-semibold"><%= d.last_name %> <%= d.first_name %> <%= d.middle_name || '' %></td>
            <td>
              <% const ad = Array.isArray(d.specializations) ? d.specializations : []; %>
              <% if (ad.length) { %>
                <div class="d-flex flex-wrap gap-1">
                  <% ad.slice(0, 4).forEach(function(sp) { %>
                    <span class="badge spec-badge<%= sp.is_primary ? '' : ' bg-light text-dark border' %>"><%= sp.name %></span>
                  <% }); %>
                  <% if (ad.length > 4) { %><span class="badge bg-secondary" title="<%= ad.map(function(x){return x.name;}).join(', ') %>">+<%= ad.length - 4 %></span><% } %>
                </div>
              <% } else { %>—<% } %>
            </td>
            <td><%= d.cabinet || '—' %></td>
            <td><%= d.experience_years || 0 %> лет</td>
            <td>
              <% if(d.is_blocked){%><span class="status-pill status-pill--blocked"><i class="bi bi-lock-fill"></i>Заблокирован</span><%}else{%><span class="status-pill status-pill--active"><i class="bi bi-check-circle"></i>Активен</span><%}%>
            </td>
            <td class="text-end">
              <a href="/admin/doctors/<%= d.id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
              <form method="POST" action="/admin/doctors/<%= d.id %>/delete" class="d-inline" onsubmit="return confirm('Удалить врача <%= d.last_name %> <%= d.first_name %>?')">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
