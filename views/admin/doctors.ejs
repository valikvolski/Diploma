<%- include('../partials/header', { title: title }) %>
<%
  var dsTitle = 'Управление врачами';
  var dsSubtitle = 'Создание, редактирование и блокировка учётных записей';
  var dsIcon = 'bi-person-badge';
  var dsActions = '<a href="/admin/doctors/new" class="btn btn-primary rounded-pill d-inline-flex align-items-center gap-1 text-nowrap"><i class="bi bi-plus-lg"></i>Добавить врача</a>';
%>
<%- include('../partials/ds-page-header', { dsTitle: dsTitle, dsSubtitle: dsSubtitle, dsIcon: dsIcon, dsActions: dsActions }) %>

<% if (success) { %><div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
<% if (error) { %><div class="alert alert-danger alert-dismissible fade show"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>

<div class="card border-0 shadow-sm mb-4 rounded-4">
  <div class="card-body p-4">
    <form method="GET" action="/admin/doctors" class="row g-3 align-items-end admin-filter-form">
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Специализация</label>
        <select name="specialization_id" class="form-select form-select-sm">
          <option value="">Все специализации</option>
          <% (specializations || []).forEach(function(s) { %>
            <option value="<%= s.id %>" <%= String(filters && filters.specialization_id || '') === String(s.id) ? 'selected' : '' %>><%= s.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-semibold">Статус</label>
        <select name="status" class="form-select form-select-sm">
          <option value="">Все</option>
          <option value="active" <%= filters && filters.status === 'active' ? 'selected' : '' %>>Активен</option>
          <option value="blocked" <%= filters && filters.status === 'blocked' ? 'selected' : '' %>>Заблокирован</option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label small fw-semibold">Поиск</label>
        <input type="text" name="search" class="form-control form-control-sm" placeholder="ФИО или email" value="<%= filters && filters.search ? filters.search : '' %>">
      </div>
      <div class="col-md-3 d-flex admin-filter-actions flex-wrap justify-content-start justify-content-md-end">
        <input type="hidden" name="limit" value="<%= pagination && pagination.limit ? pagination.limit : 10 %>">
        <button type="submit" class="btn btn-primary btn-sm px-3 text-nowrap"><i class="bi bi-search me-1"></i>Найти</button>
        <a href="/admin/doctors" class="btn btn-outline-secondary btn-sm">Сброс</a>
      </div>
    </form>
  </div>
</div>

<p class="text-muted small mb-3">Всего записей: <strong><%= totalCount || 0 %></strong></p>

<div class="app-table-wrap app-table-wrap--sticky">
  <div class="table-responsive app-table-responsive">
    <table class="table app-table table-hover align-middle mb-0">
      <thead>
        <tr><th class="text-center nowrap-heading" aria-label="Фото"></th><th class="nowrap-heading">#</th><th>ФИО</th><th>Специализация</th><th>Кабинет</th><th>Стаж</th><th>Статус</th><th class="text-end nowrap-heading">Действия</th></tr>
      </thead>
      <tbody>
        <% if (!doctors || doctors.length === 0) { %>
          <tr>
            <td colspan="8" class="p-0 border-0">
              <div class="text-center py-5 app-card app-card--static m-3">
                <div class="empty-state__icon text-muted"><i class="bi bi-inbox"></i></div>
                <p class="text-muted mb-0 mt-2">Ничего не найдено по заданным фильтрам</p>
              </div>
            </td>
          </tr>
        <% } %>
        <% (doctors || []).forEach(function(d) { %>
          <tr class="<%= d.is_blocked ? 'table-secondary' : '' %>">
            <td class="text-center align-middle py-2">
              <%- include('../partials/user-avatar', { person: d, size: 'md' }) %>
            </td>
            <td><%= d.id %></td>
            <td class="fw-semibold"><%= d.last_name %> <%= d.first_name %> <%= d.middle_name || '' %></td>
            <td>
              <% const ad = Array.isArray(d.specializations) ? d.specializations : []; %>
              <% if (ad.length) { %>
                <div class="d-flex flex-wrap gap-1">
                  <% ad.slice(0, 4).forEach(function(sp) { %>
                    <span class="badge spec-badge<%= sp.is_primary ? '' : ' bg-light text-dark border' %>"><%= sp.name %></span>
                  <% }); %>
                  <% if (ad.length > 4) { %><span class="badge bg-secondary" title="<%= ad.map(function(x){return x.name;}).join(', ') %>">+<%= ad.length - 4 %></span><% } %>
                </div>
              <% } else { %>—<% } %>
            </td>
            <td><%= d.cabinet || '—' %></td>
            <td><%= d.experience_years || 0 %> лет</td>
            <td>
              <% if(d.is_blocked){%><span class="status-pill status-pill--blocked"><i class="bi bi-lock-fill"></i>Заблокирован</span><%}else{%><span class="status-pill status-pill--active"><i class="bi bi-check-circle"></i>Активен</span><%}%>
            </td>
            <td class="text-end align-middle">
              <div class="app-table-actions">
              <a href="/admin/doctors/<%= d.id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
              <form method="POST" action="/admin/doctors/<%= d.id %>/delete" class="mb-0 js-confirm-form"
                data-confirm-title="Удаление врача"
                data-confirm-name="<%= d.last_name %> <%= d.first_name %> <%= d.middle_name || '' %>"
                data-confirm-action="Удалить">
                <%- include('../partials/csrf') %>
                <button type="button" class="btn btn-sm btn-outline-danger js-open-confirm"><i class="bi bi-trash"></i></button>
              </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%
  var p = pagination || { currentPage: 1, totalPages: 1, hasPrev: false, hasNext: false, limit: 10 };
  function doctorsPageUrl(pg) {
    const qp = new URLSearchParams();
    if (filters && filters.specialization_id) qp.set('specialization_id', filters.specialization_id);
    if (filters && filters.status) qp.set('status', filters.status);
    if (filters && filters.search) qp.set('search', filters.search);
    qp.set('limit', String(p.limit || 10));
    qp.set('page', String(pg));
    return '/admin/doctors?' + qp.toString();
  }
%>
<%- include('../partials/admin-pagination', {
  p: p,
  pageUrl: doctorsPageUrl,
  ariaLabel: 'Пагинация врачей'
}) %>

<div class="modal fade" id="adminConfirmModal" tabindex="-1" aria-labelledby="adminConfirmModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="adminConfirmModalLabel">Подтверждение действия</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
      </div>
      <div class="modal-body">
        <p class="mb-0">Вы действительно хотите выполнить действие для <strong id="adminConfirmName">этого объекта</strong>?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отмена</button>
        <button type="button" class="btn btn-danger" id="adminConfirmSubmit">Подтвердить</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    function initAdminConfirmModal() {
      var modalEl = document.getElementById('adminConfirmModal');
      if (!modalEl || !window.bootstrap) return false;
      var modal = new bootstrap.Modal(modalEl);
      var submitBtn = document.getElementById('adminConfirmSubmit');
      var nameEl = document.getElementById('adminConfirmName');
      var titleEl = document.getElementById('adminConfirmModalLabel');
      var pendingForm = null;

      document.querySelectorAll('.js-open-confirm').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var form = btn.closest('.js-confirm-form');
          if (!form) return;
          pendingForm = form;
          if (nameEl) nameEl.textContent = form.getAttribute('data-confirm-name') || 'выбранного объекта';
          if (titleEl) titleEl.textContent = form.getAttribute('data-confirm-title') || 'Подтверждение действия';
          if (submitBtn) submitBtn.textContent = form.getAttribute('data-confirm-action') || 'Подтвердить';
          modal.show();
        });
      });

      if (submitBtn) {
        submitBtn.addEventListener('click', function () {
          if (!pendingForm) return;
          pendingForm.submit();
        });
      }
      return true;
    }

    if (!initAdminConfirmModal()) {
      window.addEventListener('load', initAdminConfirmModal, { once: true });
    }
  })();
</script>

<%- include('../partials/footer') %>
