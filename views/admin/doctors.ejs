<%- include('../partials/header', { title: title }) %>

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
  <h3 class="fw-bold mb-0"><i class="bi bi-person-badge text-primary me-2"></i>Управление врачами</h3>
  <a href="/admin/doctors/new" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-1"></i>Добавить врача</a>
</div>

<% if (success) { %><div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>
<% if (error) { %><div class="alert alert-danger alert-dismissible fade show"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% } %>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr><th>#</th><th>ФИО</th><th>Специализация</th><th>Кабинет</th><th>Стаж</th><th>Статус</th><th class="text-end">Действия</th></tr>
      </thead>
      <tbody>
        <% doctors.forEach(function(d) { %>
          <tr class="<%= d.is_blocked ? 'table-secondary' : '' %>">
            <td><%= d.id %></td>
            <td class="fw-semibold"><%= d.last_name %> <%= d.first_name %> <%= d.middle_name || '' %></td>
            <td><% if(d.specialization){%><span class="badge spec-badge"><%= d.specialization %></span><%}else{%>—<%}%></td>
            <td><%= d.cabinet || '—' %></td>
            <td><%= d.experience_years || 0 %> лет</td>
            <td>
              <% if(d.is_blocked){%><span class="badge bg-danger">Заблокирован</span><%}else{%><span class="badge bg-success">Активен</span><%}%>
            </td>
            <td class="text-end">
              <a href="/admin/doctors/<%= d.id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
              <form method="POST" action="/admin/doctors/<%= d.id %>/delete" class="d-inline" onsubmit="return confirm('Удалить врача <%= d.last_name %> <%= d.first_name %>?')">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
