<footer class="footer-site mt-auto">
  <div class="footer-site__topbar" aria-hidden="true"></div>
  <div class="footer-site__inner">
    <div class="container app-container">
      <div class="row g-4 g-lg-5 py-5 footer-site__grid">
        <div class="col-12 col-lg-5">
          <div class="d-flex align-items-center gap-2 mb-3">
            <span class="app-brand-mark app-brand-mark--sm d-inline-flex align-items-center justify-content-center flex-shrink-0">
              <i class="bi bi-heart-pulse-fill"></i>
            </span>
            <span class="footer-site__brand">Запись к врачу</span>
          </div>
          <p class="footer-site__lead mb-0">
            Сервис онлайн-записи в поликлинику: каталог врачей, выбор времени и электронный талон.
          </p>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
          <div class="footer-site__title">Навигация</div>
          <ul class="list-unstyled footer-site__links mb-0">
            <li><a href="/">Главная</a></li>
            <li><a href="/doctors">Врачи</a></li>
            <% if (typeof user !== 'undefined' && user && user.role === 'patient') { %>
              <li><a href="/profile/appointments">Мои записи</a></li>
            <% } %>
            <% if (typeof user !== 'undefined' && user) { %>
              <li><a href="/notifications">Уведомления</a></li>
            <% } %>
            <% if (typeof user === 'undefined' || !user) { %>
              <li><a href="/auth/login">Вход</a></li>
              <li><a href="/auth/register">Регистрация</a></li>
            <% } %>
          </ul>
        </div>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="footer-site__title">О проекте</div>
          <p class="footer-site__meta mb-2">
            <i class="bi bi-mortarboard me-1 footer-site__meta-icon" aria-hidden="true"></i>
            БГТУ, кафедра ИСиТ <span class="footer-site__dash">·</span> дипломный проект
          </p>
          <p class="footer-site__muted small mb-0">
            Учебная демонстрация. Персональные и медицинские данные вымышлены.
          </p>
        </div>
      </div>
      <div class="footer-site__bottom py-4 d-flex flex-wrap justify-content-between align-items-center gap-3">
        <span class="footer-site__copy small mb-0">&copy; 2026 Запись к врачу</span>
        <span class="footer-site__tag small mb-0">МедЗапись</span>
      </div>
    </div>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<% if (typeof loadChoicesJs !== 'undefined' && loadChoicesJs) { %>
<script src="https://cdn.jsdelivr.net/npm/choices.js@10.2.0/public/assets/scripts/choices.min.js" crossorigin="anonymous"></script>
<% if (typeof loadAdminSpecChoices !== 'undefined' && loadAdminSpecChoices) { %>
<script src="/js/admin-spec-choices.js"></script>
<% } %>
<% if (typeof loadCatalogSpecFilter !== 'undefined' && loadCatalogSpecFilter) { %>
<script src="/js/doctors-catalog-spec-filter.js"></script>
<% } %>
<% } %>
<script src="/js/theme-toggle.js"></script>
<script src="/js/unified-calendar.js"></script>
<% if (typeof loadVacationCalendar !== 'undefined' && loadVacationCalendar) { %>
<script src="/js/vacation-calendar.js"></script>
<% } %>
<% if (typeof loadHomeAnimations !== 'undefined' && loadHomeAnimations) { %>
<script src="/js/home-animations.js"></script>
<% } %>
<% if (typeof user !== 'undefined' && user) { %>
<script>
async function updateNotificationBadge() {
  try {
    const res = await fetch('/notifications/api/unread-count');
    const data = await res.json();
    const badge = document.getElementById('notif-badge');
    if (!badge) return;
    if (data.count > 0) {
      badge.textContent = data.count > 99 ? '99+' : data.count;
      badge.classList.remove('d-none');
    } else {
      badge.classList.add('d-none');
    }
  } catch (_) {}
}
setInterval(updateNotificationBadge, 30000);
</script>
<% } %>
</body>
</html>
