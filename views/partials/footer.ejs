</main>

<footer class="footer-site mt-auto">
  <div class="footer-site__inner">
    <div class="container app-container">
      <div class="row g-4 py-5">
        <div class="col-md-4">
          <div class="d-flex align-items-center gap-2 mb-3">
            <span class="app-brand-mark app-brand-mark--sm d-inline-flex align-items-center justify-content-center">
              <i class="bi bi-heart-pulse-fill"></i>
            </span>
            <span class="fw-bold fs-5 text-white">МедЗапись</span>
          </div>
          <p class="footer-site__lead mb-0">
            Онлайн-сервис записи к врачам: удобный каталог специалистов, прозрачное расписание и электронный талон.
          </p>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
          <div class="footer-site__title">Навигация</div>
          <ul class="list-unstyled footer-site__links mb-0">
            <li><a href="/">Главная</a></li>
            <li><a href="/doctors">Врачи</a></li>
            <% if (typeof user !== 'undefined' && user && user.role === 'patient') { %>
              <li><a href="/profile/appointments">Мои записи</a></li>
            <% } %>
            <% if (typeof user === 'undefined' || !user) { %>
              <li><a href="/auth/login">Вход</a></li>
              <li><a href="/auth/register">Регистрация</a></li>
            <% } %>
          </ul>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
          <div class="footer-site__title">Сервис</div>
          <ul class="list-unstyled footer-site__links mb-0">
            <li><a href="/doctors">Запись на приём</a></li>
            <li><span class="footer-site__muted">Уведомления о изменениях</span></li>
            <li><span class="footer-site__muted">Личный кабинет пациента</span></li>
          </ul>
        </div>
        <div class="col-md-12 col-lg-3">
          <div class="footer-site__title">Контакты</div>
          <p class="footer-site__muted small mb-2">
            Демонстрационный проект (диплом). Данные вымышлены.
          </p>
          <p class="small text-white-50 mb-0">
            <i class="bi bi-building me-1"></i>Учебное заведение / поликлиника
          </p>
        </div>
      </div>
      <div class="footer-site__bottom py-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
        <span class="small text-white-50">&copy; <%= new Date().getFullYear() %> МедЗапись</span>
        <span class="small text-white-50">Сделано для защиты дипломного проекта</span>
      </div>
    </div>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<% if (typeof loadChoicesJs !== 'undefined' && loadChoicesJs) { %>
<script src="https://cdn.jsdelivr.net/npm/choices.js@10.2.0/public/assets/scripts/choices.min.js" crossorigin="anonymous"></script>
<% if (typeof loadAdminSpecChoices !== 'undefined' && loadAdminSpecChoices) { %>
<script src="/js/admin-spec-choices.js"></script>
<% } %>
<% if (typeof loadCatalogSpecFilter !== 'undefined' && loadCatalogSpecFilter) { %>
<script src="/js/doctors-catalog-spec-filter.js"></script>
<% } %>
<% } %>
<script src="/js/theme-toggle.js"></script>
<script src="/js/unified-calendar.js"></script>
<% if (typeof loadVacationCalendar !== 'undefined' && loadVacationCalendar) { %>
<script src="/js/vacation-calendar.js"></script>
<% } %>
<% if (typeof loadHomeAnimations !== 'undefined' && loadHomeAnimations) { %>
<script src="/js/home-animations.js"></script>
<% } %>
<% if (typeof user !== 'undefined' && user) { %>
<script>
async function updateNotificationBadge() {
  try {
    const res = await fetch('/notifications/api/unread-count');
    const data = await res.json();
    const badge = document.getElementById('notif-badge');
    if (!badge) return;
    if (data.count > 0) {
      badge.textContent = data.count > 99 ? '99+' : data.count;
      badge.classList.remove('d-none');
    } else {
      badge.classList.add('d-none');
    }
  } catch (_) {}
}
setInterval(updateNotificationBadge, 30000);
</script>
<% } %>
</body>
</html>
