<!DOCTYPE html>
<html lang="ru" data-bs-theme="light" data-app-theme="light" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
  <meta name="csrf-token" content="<%= csrfToken %>" />
  <% } %>
  <script>
    (function () {
      var KEY = 'medzap-theme';
      var saved = null;
      try {
        saved = localStorage.getItem(KEY);
      } catch (e) {}
      var mode = 'light';
      if (saved === 'dark' || saved === 'light') {
        mode = saved;
      } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
        mode = 'dark';
      }
      document.documentElement.setAttribute('data-app-theme', mode);
      document.documentElement.setAttribute('data-bs-theme', mode);
      document.documentElement.setAttribute('data-theme', mode);
    })();
  </script>
  <title><%= typeof title !== 'undefined' ? title : 'МедЗапись' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
  <% if (typeof loadChoicesCss !== 'undefined' && loadChoicesCss) { %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js@10.2.0/public/assets/styles/choices.min.css" crossorigin="anonymous" />
  <% } %>
</head>
<body class="app-body">
<% 
  const cp = typeof currentPath !== 'undefined' ? currentPath : '';
  function navExact(path) { return cp === path || (path === '/' && (cp === '' || cp === '/')); }
  function navStarts(prefix) { return cp.startsWith(prefix); }
%>
<header class="app-header">
<nav class="navbar navbar-expand-lg app-navbar">
  <div class="container app-container">
    <a class="navbar-brand app-brand d-flex align-items-center gap-2" href="/">
      <span class="app-brand-mark d-inline-flex align-items-center justify-content-center">
        <i class="bi bi-heart-pulse-fill"></i>
      </span>
      <span class="app-brand-text">
        <span class="app-brand-title">МедЗапись</span>
        <span class="app-brand-sub d-none d-sm-block">онлайн-сервис</span>
      </span>
    </a>

    <button class="navbar-toggler app-navbar-toggler rounded-3 border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-controls="navMenu" aria-expanded="false" aria-label="Меню">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-lg-1">
        <li class="nav-item">
          <a class="nav-link app-nav-link <%= navExact('/') ? 'active' : '' %>" href="/"><i class="bi bi-house-door me-1"></i>Главная</a>
        </li>
        <li class="nav-item">
          <a class="nav-link app-nav-link <%= navStarts('/doctors') ? 'active' : '' %>" href="/doctors"><i class="bi bi-person-badge me-1"></i>Врачи</a>
        </li>
        <% if (typeof user !== 'undefined' && user && user.role === 'patient') { %>
          <li class="nav-item">
            <a class="nav-link app-nav-link <%= navStarts('/profile/appointments') ? 'active' : '' %>" href="/profile/appointments"><i class="bi bi-journal-text me-1"></i>Мои записи</a>
          </li>
        <% } %>
        <% if (typeof user !== 'undefined' && user && user.role === 'doctor') { %>
          <li class="nav-item dropdown">
            <a class="nav-link app-nav-link dropdown-toggle <%= navStarts('/doctor') ? 'active' : '' %>" href="#" data-bs-toggle="dropdown" aria-expanded="false">
              <i class="bi bi-briefcase-fill me-1"></i>Кабинет врача
            </a>
            <ul class="dropdown-menu app-dropdown shadow border-0">
              <li><a class="dropdown-item" href="/doctor/patients"><i class="bi bi-people me-2 text-primary"></i>Пациенты</a></li>
              <li><a class="dropdown-item" href="/doctor/schedule"><i class="bi bi-calendar-week me-2 text-primary"></i>Расписание</a></li>
              <li><a class="dropdown-item" href="/doctor/time-off"><i class="bi bi-calendar-x me-2 text-primary"></i>Нерабочие дни</a></li>
            </ul>
          </li>
        <% } %>
        <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
          <li class="nav-item dropdown">
            <a class="nav-link app-nav-link dropdown-toggle <%= navStarts('/admin') ? 'active' : '' %>" href="#" data-bs-toggle="dropdown" aria-expanded="false">
              <i class="bi bi-shield-lock me-1"></i>Админ-панель
            </a>
            <ul class="dropdown-menu app-dropdown shadow border-0">
              <li><a class="dropdown-item" href="/admin/doctors"><i class="bi bi-person-badge me-2 text-primary"></i>Врачи</a></li>
              <li><a class="dropdown-item" href="/admin/users"><i class="bi bi-people me-2 text-primary"></i>Пользователи</a></li>
              <li><a class="dropdown-item" href="/admin/appointments"><i class="bi bi-journal-text me-2 text-primary"></i>Записи</a></li>
              <li><a class="dropdown-item" href="/admin/specializations"><i class="bi bi-tags me-2 text-primary"></i>Специализации</a></li>
            </ul>
          </li>
        <% } %>
      </ul>

      <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center gap-lg-1">
        <li class="nav-item d-flex align-items-center">
          <button type="button" class="btn btn-link nav-link app-theme-toggle py-2 rounded-3" title="Тема: светлая / тёмная" aria-label="Переключить тему оформления">
            <i class="bi bi-moon-stars-fill" aria-hidden="true"></i>
          </button>
        </li>
        <% if (typeof user !== 'undefined' && user) { %>
          <li class="nav-item">
            <a class="nav-link app-nav-link app-notif-btn position-relative d-inline-flex align-items-center justify-content-center rounded-3 px-2 py-2 <%= navStarts('/notifications') ? 'active' : '' %>" href="/notifications" title="Уведомления" aria-label="Уведомления">
              <i class="bi bi-bell fs-5"></i>
              <% const _unc = typeof unreadNotifCount !== 'undefined' ? unreadNotifCount : 0; %>
              <% if (_unc > 0) { %>
                <span class="position-absolute top-0 end-0 translate-middle badge rounded-pill app-notif-count" id="notif-badge"><%= _unc > 99 ? '99+' : _unc %></span>
              <% } else { %>
                <span class="position-absolute top-0 end-0 translate-middle badge rounded-pill app-notif-count d-none" id="notif-badge"></span>
              <% } %>
            </a>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link app-nav-link dropdown-toggle d-flex align-items-center gap-2 py-2 rounded-3" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <span class="app-nav-avatar-wrap d-inline-flex align-items-center justify-content-center flex-shrink-0">
                <%- include('user-avatar', { person: user, size: 'sm' }) %>
              </span>
              <span class="d-none d-md-inline text-truncate app-nav-user-name"><%= user.last_name %> <%= user.first_name %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end app-dropdown shadow border-0">
              <li>
                <span class="dropdown-item-text small text-muted text-truncate" title="<%= user.email %>"><%= user.email %></span>
              </li>
              <li><hr class="dropdown-divider" /></li>
              <% if (user.role === 'patient') { %>
                <li><a class="dropdown-item" href="/profile/appointments"><i class="bi bi-journal-text me-2 text-primary"></i>Мои записи</a></li>
                <li><a class="dropdown-item" href="/profile/edit"><i class="bi bi-pencil me-2 text-primary"></i>Профиль</a></li>
              <% } else if (user.role === 'doctor') { %>
                <li><a class="dropdown-item" href="/doctor/patients"><i class="bi bi-people me-2 text-primary"></i>Пациенты</a></li>
                <li><a class="dropdown-item" href="/doctor/schedule"><i class="bi bi-calendar-week me-2 text-primary"></i>Расписание</a></li>
                <li><a class="dropdown-item" href="/doctor/time-off"><i class="bi bi-calendar-x me-2 text-primary"></i>Нерабочие дни</a></li>
              <% } %>
              <li><hr class="dropdown-divider" /></li>
              <li>
                <form method="POST" action="/auth/logout" class="px-2 mb-0">
                  <%- include('csrf') %>
                  <button type="submit" class="dropdown-item text-danger rounded-3">
                    <i class="bi bi-box-arrow-right me-2"></i>Выйти
                  </button>
                </form>
              </li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link app-nav-link <%= navStarts('/auth/login') ? 'active' : '' %>" href="/auth/login"><i class="bi bi-box-arrow-in-right me-1"></i>Вход</a>
          </li>
          <li class="nav-item ps-lg-1">
            <a class="btn btn-primary btn-sm rounded-pill px-3 app-btn-header-cta" href="/auth/register"><i class="bi bi-person-plus me-1"></i>Регистрация</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
</header>

<main class="app-main <%= typeof fullWidth !== 'undefined' && fullWidth ? 'app-main--flush' : 'py-4' %>">
<% if (typeof fullWidth === 'undefined' || !fullWidth) { %>
  <div class="container app-container">
<% } %>
