<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Запись к врачу' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
  <div class="container">
    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
        <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
      </svg>
      Запись к врачу
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link" href="/">
            <i class="bi bi-house me-1"></i>Главная
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/doctors">
            <i class="bi bi-person-badge me-1"></i>Врачи
          </a>
        </li>
      </ul>

      <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
        <% if (typeof user !== 'undefined' && user) { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle"></i>
              <%= user.last_name %> <%= user.first_name %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <span class="dropdown-item-text small text-muted">
                  <%= user.email %>
                </span>
              </li>
              <li><hr class="dropdown-divider" /></li>
              <% if (user.role === 'patient') { %>
                <li>
                  <a class="dropdown-item" href="/profile/appointments">
                    <i class="bi bi-journal-text me-2"></i>Мои записи
                  </a>
                </li>
                <li>
                  <a class="dropdown-item" href="/profile/edit">
                    <i class="bi bi-pencil me-2"></i>Редактировать профиль
                  </a>
                </li>
              <% } else { %>
                <li>
                  <a class="dropdown-item" href="/profile">
                    <i class="bi bi-person me-2"></i>Личный кабинет
                  </a>
                </li>
              <% } %>
              <% if (user.role === 'admin') { %>
                <li>
                  <a class="dropdown-item" href="/admin">
                    <i class="bi bi-gear me-2"></i>Панель администратора
                  </a>
                </li>
              <% } %>
              <li><hr class="dropdown-divider" /></li>
              <li>
                <form method="POST" action="/auth/logout" class="px-2">
                  <button type="submit" class="dropdown-item text-danger">
                    <i class="bi bi-box-arrow-right me-2"></i>Выйти
                  </button>
                </form>
              </li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/auth/login">
              <i class="bi bi-box-arrow-in-right me-1"></i>Вход
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-light btn-sm px-3 ms-2" href="/auth/register">
              Регистрация
            </a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<main class="py-4">
  <div class="container">
