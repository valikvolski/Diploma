<%#
  Unified page header (patient home dashboard style).
  Pass: dsTitle (required), dsSubtitle (optional), dsIcon (optional, e.g. bi-person-badge),
        dsBackHref, dsBackLabel, dsActions (raw HTML string for right-side buttons)
-%>
<div class="ds-page-header mb-4">
  <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
    <div class="flex-grow-1 min-w-0">
      <% if (typeof dsBackHref !== 'undefined' && dsBackHref) { %>
        <a href="<%= dsBackHref %>" class="ds-page-back link-secondary text-decoration-none small d-inline-flex align-items-center gap-1 mb-2">
          <i class="bi bi-arrow-left"></i><%= typeof dsBackLabel !== 'undefined' ? dsBackLabel : 'Назад' %>
        </a>
      <% } %>
      <h1 class="ds-page-header__title mb-0">
        <% if (typeof dsIcon !== 'undefined' && dsIcon) { %>
          <i class="bi <%= dsIcon %> text-primary me-2"></i>
        <% } %>
        <%= typeof dsTitle !== 'undefined' ? dsTitle : '' %>
      </h1>
      <% if (typeof dsSubtitle !== 'undefined' && dsSubtitle) { %>
        <p class="ds-page-header__subtitle text-muted mb-0 mt-2"><%= dsSubtitle %></p>
      <% } %>
    </div>
    <% if (typeof dsActions !== 'undefined' && dsActions) { %>
      <div class="ds-page-header__actions flex-shrink-0 d-flex flex-wrap gap-2 align-items-center">
        <%- dsActions %>
      </div>
    <% } %>
  </div>
</div>
