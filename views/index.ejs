      <div class="row g-3" data-reveal-stagger="1">
        <% var topSpecs = guest && guest.topSpecializations ? guest.topSpecializations : []; %>
        <% if (topSpecs.length) { %>
          <% topSpecs.forEach(function(s, idx) { %>
