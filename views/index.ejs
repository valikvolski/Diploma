<script>
  (function () {
    var wrap = document.querySelector('[data-next-appointment="1"]');
    if (!wrap) return;
    var textEl = wrap.querySelector('[data-countdown-text]');
    var barEl = wrap.querySelector('[data-countdown-progress]');
    var progressWrap = wrap.querySelector('.patient-next-appt__progress');
    if (!textEl || !barEl || !progressWrap) return;

    function parseDateTime(dateYmd, timeHm) {
      if (!dateYmd || !timeHm) return null;
      var rawDate = String(dateYmd).trim();
      var t = String(timeHm).split(':').map(Number);
      var hh = t[0] || 0;
      var mm = t[1] || 0;

      // 1) Основной формат: YYYY-MM-DD
      var m1 = rawDate.match(/^(\d{4})-(\d{2})-(\d{2})$/);
      if (m1) return new Date(Number(m1[1]), Number(m1[2]) - 1, Number(m1[3]), hh, mm, 0, 0);

      // 2) Альтернативный формат: DD.MM.YYYY
      var m2 = rawDate.match(/^(\d{2})\.(\d{2})\.(\d{4})$/);
      if (m2) return new Date(Number(m2[3]), Number(m2[2]) - 1, Number(m2[1]), hh, mm, 0, 0);

      // 3) Fallback через Date parser
      var d = new Date(rawDate);
      if (Number.isNaN(d.getTime())) return null;
      d.setHours(hh, mm, 0, 0);
      return d;
    }

    function fmtDiff(ms) {
      if (ms <= 0) return 'Приём завершён';
      var totalMin = Math.floor(ms / 60000);
      var days = Math.floor(totalMin / (60 * 24));
      var hours = Math.floor((totalMin % (60 * 24)) / 60);
      var mins = totalMin % 60;
      return 'До приёма осталось: ' + days + ' дн ' + hours + ' ч ' + mins + ' мин';
    }

    function updateCountdown() {
      var apptAt = parseDateTime(wrap.getAttribute('data-appointment-date'), wrap.getAttribute('data-appointment-time'));
      if (!apptAt) return;
      var now = new Date();
      var diff = apptAt.getTime() - now.getTime();

      var bookedAtRaw = wrap.getAttribute('data-booked-at');
      var bookedAt = bookedAtRaw ? new Date(bookedAtRaw) : null;
      if (!bookedAt || Number.isNaN(bookedAt.getTime())) {
        bookedAt = new Date(now);
        bookedAt.setHours(0, 0, 0, 0);
      }
      // На случай некорректной даты бронирования в будущем.
      if (bookedAt.getTime() > now.getTime()) {
        bookedAt = new Date(now);
        bookedAt.setHours(0, 0, 0, 0);
      }
      var total = Math.max(1, apptAt.getTime() - bookedAt.getTime());
      var elapsed = Math.min(total, Math.max(0, now.getTime() - bookedAt.getTime()));
      var pct = Math.round((elapsed / total) * 100);

      if (diff <= 0) {
        textEl.textContent = 'Приём завершён';
        wrap.classList.remove('patient-next-appt--soon');
        wrap.classList.add('patient-next-appt--past');
        barEl.classList.remove('bg-primary', 'bg-warning');
        barEl.classList.add('bg-secondary');
        barEl.style.width = '100%';
        progressWrap.setAttribute('aria-valuenow', '100');
        return true;
      }

      if (diff <= 60 * 60 * 1000) {
        textEl.textContent = 'Приём скоро начнётся';
        wrap.classList.add('patient-next-appt--soon');
        wrap.classList.remove('patient-next-appt--past');
        barEl.classList.remove('bg-primary', 'bg-secondary');
        barEl.classList.add('bg-warning');
      } else {
        textEl.textContent = fmtDiff(diff);
        wrap.classList.remove('patient-next-appt--soon', 'patient-next-appt--past');
        barEl.classList.remove('bg-warning', 'bg-secondary');
        barEl.classList.add('bg-primary');
      }

      var visualPct = Math.max(0, Math.min(100, pct));
      // Чтобы бар не выглядел "сломанный" при очень малом прогрессе.
      if (visualPct > 0 && visualPct < 4) visualPct = 4;
      barEl.style.width = String(visualPct) + '%';
      progressWrap.setAttribute('aria-valuenow', String(visualPct));
      return false;
    }

    var done = updateCountdown();
    if (done) return;
    var timer = window.setInterval(function () {
      var finished = updateCountdown();
      if (finished) window.clearInterval(timer);
    }, 60000);
  })();
</script>
<% } %>

<% if (roleSafe === 'doctor') { %>
<div class="home-root home-root--doctor py-4 py-lg-5 bg-app" data-home-role="doctor">
