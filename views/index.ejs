                  <stop offset="0" stop-color="#1a6ee6" stop-opacity="0.95"/>
                  <stop offset="1" stop-color="#0ea5e9" stop-opacity="0.95"/>
                </linearGradient>
              </defs>
              <rect x="28" y="28" width="464" height="304" rx="28" fill="url(#p1)" stroke="rgba(148,163,184,0.45)"/>
              <rect x="70" y="68" width="380" height="224" rx="22" fill="rgba(255,255,255,0.7)" stroke="rgba(148,163,184,0.55)"/>
              <circle cx="150" cy="144" r="38" fill="url(#p2)"/>
              <path d="M150 126h10v18h18v10h-18v18h-10v-18h-18v-10h18z" fill="rgba(255,255,255,0.92)"/>
              <rect x="214" y="120" width="192" height="14" rx="7" fill="rgba(15,23,42,0.22)"/>
              <rect x="214" y="148" width="160" height="12" rx="6" fill="rgba(15,23,42,0.14)"/>
              <rect x="108" y="204" width="304" height="70" rx="18" fill="rgba(26,110,230,0.10)" stroke="rgba(26,110,230,0.22)"/>
