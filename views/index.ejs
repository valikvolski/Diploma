        </div>
      </div>
    </header>

    <% const _up = patient && patient.upcomingAppointments ? patient.upcomingAppointments : []; %>
    <% const _next = _up && _up.length ? _up[0] : null; %>

    <div class="row g-4">
      <div class="col-lg-8">
        <h2 class="h6 text-uppercase text-muted fw-semibold letter-spacing-wide mb-3 js-home-reveal">Ближайшая запись</h2>
        <div class="app-card border-0 shadow-sm p-4 p-lg-4 js-home-reveal">
          <% if (_next) { %>
            <div
              class="patient-next-appt"
              data-next-appointment="1"
              data-appointment-date="<%= String(_next.appointment_date).slice(0, 10) %>"
              data-appointment-time="<%= _next.appointment_time %>"
              data-booked-at="<%= _next.booked_at ? new Date(_next.booked_at).toISOString() : '' %>">
