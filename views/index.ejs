<%
function fmtDateShort(str) {
  if (!str) return '—';
  const p = String(str).substring(0, 10).split('-');
  if (p.length !== 3) return String(str);
  return `${parseInt(p[2], 10)}.${p[1]}.${p[0]}`;
}
function fmtDateTimeShort(dt) {
  if (dt == null || dt === '') return '—';
  const d = typeof dt === 'number' ? new Date(dt) : new Date(dt);
  if (Number.isNaN(d.getTime())) return '—';
  return d.toLocaleString('ru-RU', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
}
function fmtMinClock(m) {
  const h = Math.floor(m / 60);
  const mm = m % 60;
  return String(h).padStart(2, '0') + ':' + String(mm).padStart(2, '0');
}
function apptStatusClass(status) {
  if (status === 'booked') return 'status-pill status-pill--booked';
  if (status === 'completed') return 'status-pill status-pill--completed';
  return 'status-pill status-pill--cancelled';
}
function apptStatusLabel(status) {
  if (status === 'booked') return 'Забронировано';
  if (status === 'completed') return 'Завершено';
  return 'Отменено';
}
const roleSafe = typeof role !== 'undefined'
  ? role
  : ((typeof user !== 'undefined' && user && user.role) ? user.role : 'guest');
const todayLabel = new Date().toLocaleDateString('ru-RU', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
});
%>
<%- include('partials/header', { title: typeof title !== 'undefined' ? title : 'МедЗапись' }) %>

<% if (roleSafe === 'guest') { %>
<div class="home-root home-root--guest py-4 py-lg-5 bg-app" data-home-role="guest">
  <div class="container app-container">
    <nav aria-label="Навигация" class="mb-3">
      <ol class="breadcrumb mb-0 small">
        <li class="breadcrumb-item active" aria-current="page">Главная</li>
      </ol>
    </nav>

    <header class="home-patient-hero guest-home-hero app-card border-0 shadow-sm p-4 p-lg-5 mb-4 mb-lg-5 js-home-hero-item">
      <div class="row align-items-center g-4">
        <div class="col-lg-8">
          <h1 class="h2 fw-bold mb-2">Запись к врачу</h1>
          <p class="text-muted mb-0 guest-home-hero__lead">Сервис онлайн-записи в поликлинику. Выберите врача и время — без очереди в регистратуру.</p>
        </div>
        <div class="col-lg-4 text-lg-end">
          <div class="guest-home-hero__mark d-none d-md-inline-flex align-items-center justify-content-center rounded-4 ms-lg-auto" aria-hidden="true">
            <i class="bi bi-heart-pulse-fill"></i>
          </div>
        </div>
      </div>
    </header>

    <section class="mb-4 mb-lg-5" aria-labelledby="guest-cta-heading">
      <h2 id="guest-cta-heading" class="h6 text-uppercase text-muted fw-semibold letter-spacing-wide mb-3 js-home-reveal">Действия</h2>
      <div class="row g-3" data-reveal-stagger="1">
        <div class="col-12 col-md-4">
          <a href="/doctors" class="home-patient-tile home-patient-tile--accent guest-home-tile js-home-stagger h-100" data-stagger-order="0">
            <span class="home-patient-tile__icon"><i class="bi bi-search"></i></span>
            <span class="home-patient-tile__label">Найти врача</span>
          </a>
        </div>
        <div class="col-12 col-md-4">
          <a href="/auth/login" class="home-patient-tile guest-home-tile js-home-stagger h-100" data-stagger-order="1">
            <span class="home-patient-tile__icon"><i class="bi bi-box-arrow-in-right"></i></span>
            <span class="home-patient-tile__label">Войти</span>
          </a>
        </div>
        <div class="col-12 col-md-4">
          <a href="/auth/register" class="home-patient-tile guest-home-tile js-home-stagger h-100" data-stagger-order="2">
            <span class="home-patient-tile__icon"><i class="bi bi-person-plus"></i></span>
            <span class="home-patient-tile__label">Регистрация</span>
          </a>
        </div>
      </div>
    </section>

    <section class="mb-4 mb-lg-5" aria-labelledby="guest-steps-heading">
      <h2 id="guest-steps-heading" class="h6 text-uppercase text-muted fw-semibold letter-spacing-wide mb-3 js-home-reveal">Как это работает</h2>
      <div class="row g-3" data-reveal-stagger="1">
        <div class="col-md-4">
          <article class="guest-home-step app-card border-0 shadow-sm p-4 h-100 js-home-stagger" data-stagger-order="0">
            <div class="guest-home-step__num mb-3" aria-hidden="true">1</div>
            <h3 class="h6 fw-bold mb-2">Выберите врача</h3>
            <p class="text-muted small mb-0">Каталог и фильтр по специализации — без лишних данных.</p>
          </article>
        </div>
        <div class="col-md-4">
          <article class="guest-home-step app-card border-0 shadow-sm p-4 h-100 js-home-stagger" data-stagger-order="1">
            <div class="guest-home-step__num mb-3" aria-hidden="true">2</div>
            <h3 class="h6 fw-bold mb-2">Выберите время</h3>
            <p class="text-muted small mb-0">Свободные слоты по расписанию врача на выбранный день.</p>
          </article>
        </div>
        <div class="col-md-4">
          <article class="guest-home-step app-card border-0 shadow-sm p-4 h-100 js-home-stagger" data-stagger-order="2">
            <div class="guest-home-step__num mb-3" aria-hidden="true">3</div>
            <h3 class="h6 fw-bold mb-2">Получите талон</h3>
            <p class="text-muted small mb-0">После входа запись и электронный талон — в личном кабинете.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="mb-4 mb-lg-5" aria-labelledby="guest-spec-heading">
      <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-3">
        <div class="min-w-0">
          <h2 id="guest-spec-heading" class="h6 text-uppercase text-muted fw-semibold letter-spacing-wide mb-1 js-home-reveal">Популярные специализации</h2>
          <p class="small text-muted mb-0 js-home-reveal">Направления из каталога — можно записаться к врачу онлайн.</p>
        </div>
        <a href="/doctors" class="btn btn-sm btn-outline-primary rounded-pill flex-shrink-0 js-home-reveal">Показать все специализации</a>
      </div>
      <div class="row g-3" data-reveal-stagger="1">
        <% var topSpecs = guest && guest.topSpecializations ? guest.topSpecializations : []; %>
        <% if (topSpecs.length) { %>
          <% topSpecs.forEach(function(s, idx) { %>
            <div class="col-6 col-lg-3">
              <a href="/doctors" class="guest-top-spec-card js-home-stagger h-100 text-decoration-none" data-stagger-order="<%= idx %>">
                <span class="guest-top-spec-card__name"><%= s.name %></span>
                <span class="guest-top-spec-card__hint">Доступны врачи в каталоге</span>
              </a>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-12">
            <div class="app-card border-0 shadow-sm p-4 text-center">
              <p class="text-muted small mb-0">Специализации появятся после настройки справочника.</p>
              <a href="/doctors" class="btn btn-sm btn-primary rounded-pill mt-3">Открыть каталог врачей</a>
            </div>
          </div>
        <% } %>
      </div>
    </section>

    <% if (guest && guest.previewDoctors && guest.previewDoctors.length) { %>
    <section class="mb-2" aria-labelledby="guest-docs-heading">
      <h2 id="guest-docs-heading" class="h6 text-uppercase text-muted fw-semibold letter-spacing-wide mb-3 js-home-reveal">Врачи из каталога</h2>
      <p class="small text-muted mb-3 js-home-reveal">Примеры специалистов. Полный список и запись — после регистрации.</p>
      <div class="row g-3" data-reveal-stagger="1">
        <% guest.previewDoctors.forEach(function(d, idx) { %>
          <% var pspecs = [];
             try {
               if (Array.isArray(d.specializations)) pspecs = d.specializations;
               else if (typeof d.specializations === 'string' && d.specializations) pspecs = JSON.parse(d.specializations);
             } catch (e) { pspecs = []; }
             var primSpec = pspecs.filter(function(x){ return x.is_primary; })[0] || pspecs[0];
          %>
          <div class="col-md-6 col-lg-4">
            <article class="guest-home-doctor app-card border-0 shadow-sm p-4 h-100 d-flex flex-column align-items-center text-center js-home-stagger" data-stagger-order="<%= idx %>">
              <div class="guest-doctor-card__avatar mx-auto mb-3">
                <%- include('partials/user-avatar', { person: d, size: 'card' }) %>
              </div>
              <h3 class="h6 fw-bold mb-1">
                <%= d.last_name %> <%= d.first_name %><% if (d.middle_name) { %> <%= d.middle_name %><% } %>
              </h3>
              <p class="small text-muted mb-3 flex-grow-1"><%= primSpec ? primSpec.name : 'Врач' %></p>
              <a href="/doctors/<%= d.id %>" class="btn btn-outline-primary btn-sm rounded-pill w-100 mt-auto">Подробнее</a>
            </article>
          </div>
        <% }); %>
      </div>
      <div class="text-center mt-4">
        <a href="/doctors" class="btn btn-primary rounded-pill px-4"><i class="bi bi-grid-3x3-gap me-2"></i>Все врачи</a>
      </div>
    </section>
    <% } %>
  </div>
</div>
<% } %>

<% if (roleSafe === 'patient') { %>
<% const _unread = typeof unreadNotifCount !== 'undefined' ? unreadNotifCount : 0; %>
<% const _notifPreview = patient && patient.unreadNotifications ? patient.unreadNotifications : []; %>
<div class="home-root home-root--patient py-4 py-lg-5 bg-app" data-home-role="patient">
  <div class="container app-container">
    <nav aria-label="Навигация" class="mb-3">
      <ol class="breadcrumb mb-0 small">
        <li class="breadcrumb-item active" aria-current="page">Главная</li>
      </ol>
    </nav>

    <header class="home-patient-hero app-card border-0 shadow-sm p-4 p-lg-5 mb-4 js-home-hero-item">
      <div class="row align-items-center g-3">
        <div class="col">
          <h1 class="h2 fw-bold mb-2">
            Здравствуйте, <%= user.first_name %>! <span class="home-wave" aria-hidden="true">👋</span>
          </h1>
          <p class="text-muted mb-0">Запись к врачу, талоны и напоминания — в одном месте.</p>
        </div>
        <div class="col-auto d-none d-sm-block">
          <div class="home-patient-hero__mark d-flex align-items-center justify-content-center rounded-4">
            <i class="bi bi-heart-pulse-fill"></i>
          </div>
        </div>
      </div>
    </header>

    <section class="mb-4 mb-lg-5" aria-labelledby="patient-quick-heading">
      <h2 id="patient-quick-heading" class="h6 text-uppercase text-muted fw-semibold letter-spacing-wide mb-3 js-home-reveal">
        Быстрые действия
      </h2>
      <div class="row g-3" data-reveal-stagger="1">
        <div class="col-6 col-md-3">
          <a href="/doctors" class="home-patient-tile home-patient-tile--accent js-home-stagger h-100" data-stagger-order="0">
            <span class="home-patient-tile__icon"><i class="bi bi-calendar-plus"></i></span>
            <span class="home-patient-tile__label">Запись к врачу</span>
          </a>
        </div>
        <div class="col-6 col-md-3">
          <a href="/profile/appointments" class="home-patient-tile js-home-stagger h-100" data-stagger-order="1">
            <span class="home-patient-tile__icon"><i class="bi bi-journal-text"></i></span>
            <span class="home-patient-tile__label">Мои записи</span>
          </a>
        </div>
        <div class="col-6 col-md-3">
          <a href="/notifications" class="home-patient-tile js-home-stagger h-100 position-relative" data-stagger-order="2">
            <% if (_unread > 0) { %>
              <span class="position-absolute top-0 end-0 translate-middle badge rounded-pill bg-danger home-patient-tile__badge"><%= _unread > 99 ? '99+' : _unread %></span>
            <% } %>
            <span class="home-patient-tile__icon"><i class="bi bi-bell"></i></span>
            <span class="home-patient-tile__label">Уведомления</span>
          </a>
        </div>
        <div class="col-6 col-md-3">
          <a href="/profile/edit" class="home-patient-tile js-home-stagger h-100" data-stagger-order="3">
            <span class="home-patient-tile__icon"><i class="bi bi-person"></i></span>
            <span class="home-patient-tile__label">Профиль</span>
          </a>
        </div>
      </div>
    </section>

    <div class="row g-4">
      <div class="col-lg-7">
        <h2 class="h6 text-uppercase text-muted fw-semibold letter-spacing-wide mb-3 js-home-reveal">Ближайшие записи</h2>
        <div class="app-card border-0 shadow-sm p-4 p-md-4 h-100 js-home-reveal">
          <% if (patient && patient.upcomingAppointments && patient.upcomingAppointments.length) { %>
            <ul class="list-unstyled mb-0 d-flex flex-column gap-3" data-reveal-stagger="1">
              <% patient.upcomingAppointments.forEach(function(a, i) { %>
                <li class="home-patient-appt js-home-stagger" data-stagger-order="<%= i %>">
                  <div class="home-patient-appt__main">
                    <div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
                      <div>
                        <div class="fw-semibold"><%= a.doctor_last_name %> <%= a.doctor_first_name %> <%= a.doctor_middle_name || '' %></div>
                        <div class="small text-muted"><%= a.specialization || 'Специализация не указана' %></div>
                      </div>
                      <% if (a.ticket_id) { %>
                        <a href="/tickets/<%= a.ticket_id %>" class="btn btn-sm btn-primary rounded-pill flex-shrink-0">
                          <i class="bi bi-ticket-perforated me-1"></i>Талон
                        </a>
                      <% } %>
                    </div>
                    <div class="home-patient-appt__meta small text-muted mt-2 d-flex flex-wrap gap-3">
                      <span><i class="bi bi-calendar3 me-1"></i><%= fmtDateShort(a.appointment_date) %></span>
                      <span><i class="bi bi-clock me-1"></i><%= a.appointment_time %></span>
                      <% if (a.cabinet) { %>
                        <span><i class="bi bi-door-open me-1"></i>Каб. <%= a.cabinet %></span>
                      <% } %>
                    </div>
                  </div>
                </li>
              <% }) %>
            </ul>
            <div class="mt-4 pt-3 border-top">
              <a href="/profile/appointments" class="btn btn-outline-primary btn-sm rounded-pill">Все записи</a>
            </div>
          <% } else { %>
            <div class="text-center py-4 px-2 home-patient-empty">
              <div class="home-patient-empty__icon text-muted mb-3"><i class="bi bi-calendar-heart"></i></div>
              <h3 class="h6 fw-semibold mb-2">Пока нет предстоящих визитов</h3>
              <p class="text-muted small mb-4 mx-auto home-patient-empty__text">Выберите врача и удобное время — талон появится здесь и в разделе «Мои записи».</p>
              <a href="/doctors" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-calendar-plus me-2"></i>Записаться к врачу
              </a>
            </div>
          <% } %>
        </div>
      </div>
      <div class="col-lg-5">
        <h2 class="h6 text-uppercase text-muted fw-semibold letter-spacing-wide mb-3 js-home-reveal">Уведомления</h2>
        <div class="app-card border-0 shadow-sm p-4 h-100 js-home-reveal d-flex flex-column">
          <% if (_unread > 0 && _notifPreview.length) { %>
            <p class="small text-muted mb-3">Непрочитано: <strong class="text-body"><%= _unread > 99 ? '99+' : _unread %></strong></p>
            <ul class="list-unstyled mb-0 flex-grow-1 d-flex flex-column gap-3">
              <% _notifPreview.slice(0, 3).forEach(function(n) { %>
                <li class="home-notif-preview-item">
                  <div class="fw-semibold small text-truncate" title="<%= n.title %>"><%= n.title %></div>
                  <p class="small text-muted mb-0 home-notif-preview-item__msg"><%= n.message %></p>
                  <div class="small text-muted mt-1"><%= fmtDateTimeShort(n.created_at) %></div>
                </li>
              <% }) %>
            </ul>
            <a href="/notifications" class="btn btn-outline-primary rounded-pill mt-4">Открыть все</a>
          <% } else if (_unread > 0) { %>
            <p class="fw-semibold mb-2">У вас <%= _unread > 99 ? '99+' : _unread %> непрочитанных уведомлений</p>
            <p class="small text-muted mb-4">Откройте центр уведомлений, чтобы прочитать сообщения.</p>
            <a href="/notifications" class="btn btn-primary rounded-pill mt-auto">Перейти к уведомлениям</a>
          <% } else { %>
            <div class="text-center py-3 home-patient-empty flex-grow-1 d-flex flex-column justify-content-center">
              <div class="home-patient-empty__icon text-muted mb-3"><i class="bi bi-bell-slash"></i></div>
              <p class="text-muted small mb-0">Новых уведомлений нет. Мы сообщим, если что-то изменится в ваших записях.</p>
            </div>
            <a href="/notifications" class="btn btn-link btn-sm text-decoration-none mt-3">История уведомлений</a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
<% } %>

<% if (roleSafe === 'doctor') { %>
<div class="home-root home-root--doctor py-4 py-lg-5 bg-app" data-home-role="doctor">
  <div class="container app-container">
    <header class="home-dash-header mb-4 js-home-hero-item animate-fadeIn">
      <h1 class="home-dash-title fw-bold mb-1">
        Добро пожаловать, <%= user.first_name %><%= user.middle_name ? ' ' + user.middle_name : '' %>!
      </h1>
      <p class="text-muted mb-0"><i class="bi bi-calendar-event me-1"></i><%= todayLabel %></p>
    </header>

    <div class="row g-4 mb-4">
      <div class="col-lg-4">
        <div class="home-doctor-summary app-card p-4 h-100 js-home-reveal">
          <h2 class="h6 text-uppercase text-muted fw-bold mb-3">Сегодня</h2>
          <% const tc = doctor ? doctor.todayCount : 0; %>
          <div class="home-doctor-summary__count text-primary fw-bold mb-2" data-count-up="<%= tc %>">0</div>
          <p class="text-muted small mb-0">
            <% if (tc > 0) { %>
              <% if (doctor && doctor.nextPatient) { %>
                Следующий: <strong class="text-body"><%= doctor.nextPatient.last_name %> <%= doctor.nextPatient.first_name %></strong>
                в <strong class="text-body"><%= doctor.nextPatient.appointment_time %></strong>
              <% } else { %>
                Записи на сегодня есть — откройте список пациентов.
              <% } %>
            <% } else { %>
              Свободный день — записей на сегодня нет.
            <% } %>
          </p>
        </div>
      </div>
      <div class="col-lg-8">
        <h2 class="h6 text-uppercase text-muted fw-bold mb-3 js-home-reveal">Быстрые действия</h2>
        <div class="row g-3" data-reveal-stagger="1">
          <div class="col-md-4">
            <a href="/doctor/patients" class="home-dash-action js-home-stagger h-100" data-stagger-order="0">
              <span class="home-dash-action__icon"><i class="bi bi-people"></i></span>
              <span>Пациенты на сегодня</span>
            </a>
          </div>
          <div class="col-md-4">
            <a href="/doctor/schedule" class="home-dash-action js-home-stagger h-100" data-stagger-order="1">
              <span class="home-dash-action__icon"><i class="bi bi-calendar-week"></i></span>
              <span>Моё расписание</span>
            </a>
          </div>
          <div class="col-md-4">
            <a href="/doctor/time-off" class="home-dash-action js-home-stagger h-100" data-stagger-order="2">
              <span class="home-dash-action__icon"><i class="bi bi-calendar-x"></i></span>
              <span>Нерабочие дни</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="app-card p-4 js-home-reveal">
      <h2 class="h6 fw-bold mb-3"><i class="bi bi-clock-history text-primary me-2"></i>Расписание на сегодня</h2>
      <% if (doctor && doctor.timeline && doctor.timeline.items && doctor.timeline.items.length) { %>
        <div class="home-timeline">
          <div class="home-timeline__axis text-muted small mb-2 d-flex justify-content-between">
            <span><%= fmtMinClock(doctor.timeline.startMin) %></span>
            <span><%= fmtMinClock(doctor.timeline.endMin) %></span>
          </div>
          <div class="home-timeline__track">
            <% doctor.timeline.items.forEach(function(it) { %>
              <div class="home-timeline__block" style="left:<%= it.leftPct %>%;width:<%= it.widthPct %>%;" title="<%= it.appointment_time %> · <%= it.last_name %> <%= it.first_name %>">
                <span class="home-timeline__block-time"><%= it.appointment_time %></span>
                <span class="home-timeline__block-name text-truncate"><%= it.last_name %> <%= it.first_name && it.first_name[0] ? it.first_name[0] + '.' : '' %></span>
              </div>
            <% }) %>
          </div>
          <p class="small text-muted mt-3 mb-0">Блоки показывают занятые интервалы. Подробный список — в разделе «Пациенты».</p>
        </div>
      <% } else { %>
        <p class="text-muted mb-0">На сегодня нет записей в расписании.</p>
      <% } %>
    </div>
  </div>
</div>
<% } %>

<% if (roleSafe === 'admin') { %>
<div class="home-root home-root--admin py-4 py-lg-5 bg-app" data-home-role="admin">
  <div class="container app-container">
    <header class="home-dash-header mb-4 js-home-hero-item animate-fadeIn">
      <h1 class="home-dash-title fw-bold mb-1">Панель администратора</h1>
      <p class="text-muted mb-0"><i class="bi bi-calendar-event me-1"></i><%= todayLabel %></p>
    </header>

    <p class="small text-muted mb-3 js-home-reveal d-none d-md-block">
      <i class="bi bi-info-circle me-1"></i>Сводка и аналитика видны только администраторам. Детальный обзор — <a href="/admin" class="text-decoration-none">страница «Админ-панель»</a>.
    </p>

    <div class="row g-3 mb-4" data-reveal-stagger="1">
      <div class="col-sm-6 col-xl-3">
        <div class="home-admin-stat app-card p-4 js-home-stagger" data-stagger-order="0">
          <i class="bi bi-person-badge text-primary fs-4 mb-2 d-block"></i>
          <div class="home-admin-stat__num text-primary" data-count-up="<%= admin && admin.stats ? admin.stats.doctors : 0 %>">0</div>
          <div class="small text-muted">Врачей</div>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="home-admin-stat app-card p-4 js-home-stagger" data-stagger-order="1">
          <i class="bi bi-people text-primary fs-4 mb-2 d-block"></i>
          <div class="home-admin-stat__num text-primary" data-count-up="<%= admin && admin.stats ? admin.stats.patients : 0 %>">0</div>
          <div class="small text-muted">Пациентов</div>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="home-admin-stat app-card p-4 js-home-stagger" data-stagger-order="2">
          <i class="bi bi-calendar-check text-primary fs-4 mb-2 d-block"></i>
          <div class="home-admin-stat__num text-primary" data-count-up="<%= admin && admin.stats ? admin.stats.todayAppointments : 0 %>">0</div>
          <div class="small text-muted">Записей на сегодня</div>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="home-admin-stat app-card p-4 js-home-stagger" data-stagger-order="3">
          <i class="bi bi-tags text-primary fs-4 mb-2 d-block"></i>
          <div class="home-admin-stat__num text-primary" data-count-up="<%= admin && admin.stats ? admin.stats.specializations : 0 %>">0</div>
          <div class="small text-muted">Специализаций</div>
        </div>
      </div>
    </div>

    <% if (admin && admin.chartPayload) { %>
    <h2 class="h6 text-uppercase text-muted fw-bold mb-3 js-home-reveal">Аналитика</h2>
    <div class="row g-4 mb-4">
      <div class="col-lg-7">
        <div class="app-card border-0 shadow-sm p-4 h-100 admin-chart-card">
          <h3 class="h6 fw-bold mb-1">Записи по дням</h3>
          <p class="small text-muted mb-3">Количество записей с датой приёма за последние 14 дней (включая сегодня).</p>
          <div class="admin-chart-canvas-wrap">
            <canvas id="admin-chart-appts-by-day" aria-label="График записей по дням"></canvas>
          </div>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="app-card border-0 shadow-sm p-4 h-100 admin-chart-card">
          <h3 class="h6 fw-bold mb-1">Статусы записей</h3>
          <p class="small text-muted mb-3">Распределение всех записей в системе по статусу.</p>
          <div class="admin-chart-canvas-wrap admin-chart-canvas-wrap--doughnut">
            <canvas id="admin-chart-status" aria-label="Диаграмма статусов записей"></canvas>
          </div>
        </div>
      </div>
    </div>
    <script type="application/json" id="admin-home-chart-json"><%- JSON.stringify(admin.chartPayload).replace(/</g, '\\u003c') %></script>
    <% } %>

    <h2 class="h6 text-uppercase text-muted fw-bold mb-3 js-home-reveal">Быстрые действия</h2>
    <div class="row g-3 mb-4" data-reveal-stagger="1">
      <div class="col-md-3"><a class="home-dash-action js-home-stagger" data-stagger-order="0" href="/admin/doctors"><span class="home-dash-action__icon"><i class="bi bi-person-badge"></i></span><span>Управление врачами</span></a></div>
      <div class="col-md-3"><a class="home-dash-action js-home-stagger" data-stagger-order="1" href="/admin/users"><span class="home-dash-action__icon"><i class="bi bi-people"></i></span><span>Пользователи</span></a></div>
      <div class="col-md-3"><a class="home-dash-action js-home-stagger" data-stagger-order="2" href="/admin/appointments"><span class="home-dash-action__icon"><i class="bi bi-journal-text"></i></span><span>Все записи</span></a></div>
      <div class="col-md-3"><a class="home-dash-action js-home-stagger" data-stagger-order="3" href="/admin/specializations"><span class="home-dash-action__icon"><i class="bi bi-tags"></i></span><span>Специализации</span></a></div>
    </div>

    <div class="app-card p-4 js-home-reveal">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h2 class="h6 fw-bold mb-0"><i class="bi bi-activity text-primary me-2"></i>Последняя активность</h2>
        <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" onclick="location.reload()">
          <i class="bi bi-arrow-clockwise me-1"></i>Обновить
        </button>
      </div>
      <% if (admin && admin.recentActivity && admin.recentActivity.length) { %>
        <ul class="list-unstyled mb-0 home-activity-list">
          <% admin.recentActivity.forEach(function(ev) { %>
            <li class="home-activity-item d-flex gap-3 py-2 border-bottom admin-activity-border">
              <span class="home-activity-item__dot <%= ev.kind === 'appointment' ? 'bg-primary' : 'bg-success' %>"></span>
              <div class="flex-grow-1 min-w-0">
                <div class="fw-semibold small"><%= ev.title %></div>
                <div class="small text-muted text-break"><%= ev.meta %></div>
              </div>
              <div class="small text-muted text-nowrap flex-shrink-0"><%= ev.at ? fmtDateTimeShort(ev.at) : '—' %></div>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="text-muted mb-0">Пока нет событий для отображения.</p>
      <% } %>
    </div>
  </div>
</div>
<% if (roleSafe === 'admin' && admin && admin.chartPayload) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="/js/admin-home-charts.js"></script>
<% } %>
<% } %>

<%- include('partials/footer') %>
