# Скопируйте в .env и подставьте свои значения. Не коммитьте .env.

# Если приложение за прокси с префиксом (https://site.ru/clinic/...):
# APP_BASE_PATH=/clinic

PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_NAME=clinic_db

# Опционально: автозапуск миграций при старте (только не в production)
# AUTO_RUN_DB_MIGRATIONS=1

# JWT — сгенерируйте длинные случайные строки (например: openssl rand -hex 32)
JWT_ACCESS_SECRET=change_me_min_16_chars_random_string
JWT_REFRESH_SECRET=change_me_min_16_chars_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Сброс пароля (код по email): HMAC-шифрование кода; по умолчанию используется JWT_ACCESS_SECRET
# PASSWORD_RESET_CODE_PEPPER=
# PASSWORD_RESET_EXPIRES_MINUTES=10
# PASSWORD_RESET_MAX_EMAILS_PER_HOUR=5

# Cookies: true на HTTPS в продакшене
COOKIE_SECURE=false

# Google OAuth (опционально; без CLIENT_ID кнопка «Google» скрыта)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Публичный URL сайта (ссылки в письмах). Без слэша в конце.
# На localhost ссылка «Открыть талон» в письме помечается как доступная только с вашего ПК.
APP_BASE_URL=http://localhost:3000

# PDF талона во вложении к письмам (HTML как на сайте → Puppeteer → PDF). false — только HTML в письме.
EMAIL_ATTACH_TICKET_PDF=false
# Linux/Docker при необходимости: PUPPETEER_NO_SANDBOX=1
# Свой Chrome/Chromium: PUPPETEER_EXECUTABLE_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
# Доп. аргументы браузера: PUPPETEER_ARGS=--disable-gpu

# SMTP (письма пациентам). Без SMTP_HOST письма не отправляются.
# Gmail (разработка): пароль приложения https://myaccount.google.com/apppasswords
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=vailpo578@gmail.com
SMTP_PASS=uwmf rhlk iruc abmr
MAIL_FROM="МедЗапись <no-reply@example.com>"

