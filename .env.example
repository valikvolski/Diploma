# Скопируйте в .env и подставьте свои значения. Не коммитьте .env.

# Если приложение за прокси с префиксом (https://site.ru/clinic/...):
# APP_BASE_PATH=/clinic

PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_NAME=clinic_db

# Опционально: автозапуск миграций при старте (только не в production)
# AUTO_RUN_DB_MIGRATIONS=1

# JWT — сгенерируйте длинные случайные строки (например: openssl rand -hex 32)
JWT_ACCESS_SECRET=change_me_min_16_chars_random_string
JWT_REFRESH_SECRET=change_me_min_16_chars_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Cookies: true на HTTPS в продакшене
COOKIE_SECURE=false

# Google OAuth (опционально; без CLIENT_ID кнопка «Google» скрыта)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
